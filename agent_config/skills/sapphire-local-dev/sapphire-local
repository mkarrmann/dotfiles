#!/usr/bin/env bash
# sapphire-local: Run Sapphire (Presto-on-Spark) Java or Velox with the driver on this devvm.
#
# Wraps sapphire-submit.sh with the working "default-mode" recipe (no -l, no -x),
# auto-strips AI-agent env vars (the WS anti-AI gate trips on CLAUDE_*/ANTHROPIC_*/FB_AGENT_*),
# names the log deterministically, and provides an `extract` subcommand that pulls the
# "Rows: N\n[value]" result block out of the driver log.
#
# See ~/.claude/skills/sapphire-local-dev/SKILL.md for the full story.

set -uo pipefail

usage() {
  cat <<'EOF'
Usage: sapphire-local <subcommand> [options] [-- <extra sapphire-submit args>]

SUBCOMMANDS:
  velox -n <ns> -f <sql>          Run query under Sapphire Velox (Prestissimo).
  java  -n <ns> -f <sql>          Run query under Sapphire Java.
  ab    -n <ns> -f <sql>          Run BOTH Java and Velox, then diff results.
  extract <log>                   Print "Rows: N\n[value]" and the PoS query id from a log.
  help                            Show this message.

OPTIONS (velox/java/ab):
  -n, --namespace <ns>            Sapphire namespace (instagram, ad_delivery, di, ...). Required.
  -f, --file <sql>                Path to SQL file. Required. NO trailing semicolon.
  -j, --java-pkg <ver>            presto.spark version (default: stable_fb34).
  -c, --cpp-pkg <ver>             presto.presto_on_spark_cpp version (default: prestissimo-deployed).
                                  Velox subcommand sets this automatically; ignored for `java`.
  -g, --tag <tag>                 Client tag (default: SAPPHIRE_VELOX_SPARK3 for velox, omitted for java).
      --log-dir <dir>             Where to write the driver log (default: /tmp).
      --no-env-strip              Don't auto-strip AI-agent env vars (you've already cleaned them).
      --dry-run                   Print the command that would run, don't execute.
  --                              Everything after -- is passed through to sapphire-submit.sh
                                  verbatim (e.g. -s key=val, -e spark.foo=bar). Note: -l and -x
                                  are rejected here (use a different skill for those).

EXAMPLES:
  sapphire-local velox -n instagram -f /tmp/mmc_count.sql
  sapphire-local java  -n instagram -f /tmp/mmc_count.sql
  sapphire-local ab    -n instagram -f /tmp/mmc_count.sql
  sapphire-local velox -n ad_delivery -f /tmp/q.sql -- -s spill_enabled=true -e spark.driver.memory=20g
  sapphire-local extract /tmp/sapphire_local_velox_20260613_211135.log
EOF
}

die() { echo "sapphire-local: $*" >&2; exit 2; }

#---- env-strip helper -------------------------------------------------------
# WS anti-AI gate rejects directory creation if it sees CLAUDE_*/ANTHROPIC_*/FB_AGENT_*
# in the process env. Re-exec under env -i with only the minimum.
maybe_reexec_clean() {
  # Skip if user asked us to, or if we've already re-execed.
  if [[ "${SAPPHIRE_LOCAL_ENV_STRIPPED:-}" == "1" || "${NO_ENV_STRIP:-}" == "1" ]]; then
    return 0
  fi
  # If no agent vars present, no need.
  if ! env | grep -qE '^(CLAUDE_|ANTHROPIC_|FB_AGENT_)'; then
    return 0
  fi
  echo "sapphire-local: AI-agent env vars detected; re-execing under env -i (use --no-env-strip to skip)" >&2
  exec env -i \
    HOME="$HOME" \
    PATH="$PATH" \
    USER="$USER" \
    TERM="${TERM:-xterm}" \
    SSH_AUTH_SOCK="${SSH_AUTH_SOCK:-}" \
    SAPPHIRE_LOCAL_ENV_STRIPPED=1 \
    "$0" "$@"
}

#---- repo + script discovery -----------------------------------------------
# Find the fbsource root the user's pwd is in (handles checkout1/checkout2/checkout3).
find_fbsource_root() {
  local d="${PWD:-$HOME}"
  while [[ "$d" != "/" ]]; do
    if [[ -d "$d/fbcode/fb_sapphire_cpp/scripts" ]]; then
      echo "$d"; return 0
    fi
    d="$(dirname "$d")"
  done
  # Fall back to common locations in priority order.
  for c in "$HOME/fbsource" "$HOME/checkout1/fbsource" "$HOME/checkout2/fbsource" "$HOME/checkout3/fbsource" "$HOME/checkout4/fbsource"; do
    if [[ -d "$c/fbcode/fb_sapphire_cpp/scripts" ]]; then
      echo "$c"; return 0
    fi
  done
  return 1
}

#---- result extraction ------------------------------------------------------
# Sapphire prints results to the driver log as:
#   Rows: N
#   [val1\tval2\t...]
# (one bracketed line per row). Find the LAST such block â€” earlier "Rows:" hits
# can be unrelated planner stats.
extract_result() {
  local log="$1"
  [[ -f "$log" ]] || die "log not found: $log"
  echo "===== Result ====="
  # Find the last line matching "^Rows: N$"; print it + the next line.
  local last_rows_line
  last_rows_line="$(grep -an '^Rows: [0-9]\+$' "$log" | tail -1 | cut -d: -f1)"
  if [[ -n "$last_rows_line" ]]; then
    sed -n "${last_rows_line},$((last_rows_line + 1))p" "$log"
  else
    echo "(no 'Rows: N' result block found â€” query may have produced no result set, e.g. CTAS)"
  fi
  echo
  echo "===== Presto-on-Spark query id (zero-counter) ====="
  grep -aoE '[0-9]{8}_[0-9]{6}_00000_[a-z0-9]+' "$log" | sort -u | head -5
  echo
  echo "===== Presto EXPLAIN query id (high counter) ====="
  grep -aoE '[0-9]{8}_[0-9]{6}_[1-9][0-9]+_[a-z0-9]+' "$log" | sort -u | head -5
  echo
  echo "===== Exit / failure signals ====="
  grep -aE 'Spark driver terminated with exit code|EXIT=|unable to fetch tempfs tier|WSE_INVALID_ARGUMENT|Unknown session property|exit code 69' "$log" | tail -10 || true
}

#---- run helper -------------------------------------------------------------
# Args:
#   $1 = engine ("java" or "velox")
#   $2 = namespace
#   $3 = sql file
#   $4 = java pkg (-j)
#   $5 = cpp pkg (-c)  (empty for java)
#   $6 = client tag (-g) (empty to omit)
#   $7 = log file (output)
#   $8 = dry-run? ("1" / "")
#   shift 8; then "$@" = extra args to forward verbatim
run_engine() {
  local engine="$1" ns="$2" sql="$3" jpkg="$4" cpkg="$5" tag="$6" log="$7" dryrun="$8"
  shift 8

  local root
  root="$(find_fbsource_root)" || die "couldn't locate fbsource root (no fbcode/fb_sapphire_cpp/scripts found in pwd ancestry or ~/checkout*/fbsource)"
  local submit="$root/fbcode/fb_sapphire_cpp/scripts/sapphire-submit.sh"
  [[ -x "$submit" ]] || die "sapphire-submit.sh not executable at $submit"

  [[ -f "$sql" ]] || die "sql file not found: $sql"
  # Reject trailing ; (sapphire wraps in EXPLAIN as single statement; ; breaks parser).
  if grep -qE ';[[:space:]]*$' "$sql"; then
    die "sql file ends with ';' which breaks sapphire's EXPLAIN wrapper. Remove the trailing semicolon."
  fi

  # Build arg list.
  local -a cmd=(bash "$submit" --spark3 -j "$jpkg" -n "$ns" -f "$sql")
  if [[ -n "$cpkg" ]]; then
    cmd+=(-c "$cpkg")
  fi
  if [[ -n "$tag" ]]; then
    cmd+=(-g "$tag")
  fi
  # Forwarded extras.
  cmd+=("$@")

  echo "sapphire-local: engine=$engine"
  echo "sapphire-local: fbsource=$root"
  echo "sapphire-local: log=$log"
  echo "sapphire-local: cmd=${cmd[*]}"
  echo "sapphire-local: starting at $(date -Is) ..."

  if [[ "$dryrun" == "1" ]]; then
    echo "sapphire-local: DRY RUN â€” not executing."
    return 0
  fi

  local started ended rc
  started="$(date +%s)"
  ( cd "$root" && "${cmd[@]}" ) > "$log" 2>&1
  rc=$?
  ended="$(date +%s)"

  echo "sapphire-local: finished at $(date -Is) (wall=$((ended - started))s, EXIT=$rc)"
  echo
  extract_result "$log"
  return "$rc"
}

#---- subcommand parsing -----------------------------------------------------
[[ $# -ge 1 ]] || { usage >&2; exit 2; }

sub="$1"; shift

case "$sub" in
  help|-h|--help) usage; exit 0 ;;
  extract)
    [[ $# -ge 1 ]] || die "extract requires <log> path"
    extract_result "$1"
    exit 0
    ;;
  java|velox|ab) ;;  # handled below
  *) die "unknown subcommand: $sub (try 'sapphire-local help')" ;;
esac

# Parse options for java/velox/ab.
ns=""
sql=""
jpkg="stable_fb34"
cpkg=""
tag=""
log_dir="/tmp"
dryrun=""
NO_ENV_STRIP="${NO_ENV_STRIP:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--namespace) ns="$2"; shift 2 ;;
    -f|--file)      sql="$2"; shift 2 ;;
    -j|--java-pkg)  jpkg="$2"; shift 2 ;;
    -c|--cpp-pkg)   cpkg="$2"; shift 2 ;;
    -g|--tag)       tag="$2"; shift 2 ;;
       --log-dir)   log_dir="$2"; shift 2 ;;
       --no-env-strip) NO_ENV_STRIP=1; shift ;;
       --dry-run)   dryrun=1; shift ;;
    --)             shift; break ;;
    -h|--help)      usage; exit 0 ;;
    *) die "unknown option: $1 (use -- before sapphire-submit passthrough args)" ;;
  esac
done

# Validate.
[[ -n "$ns"  ]] || die "missing -n/--namespace"
[[ -n "$sql" ]] || die "missing -f/--file"

# Reject -l / -x in the passthrough â€” they defeat the purpose of this skill.
for a in "$@"; do
  case "$a" in
    -l|--local) die "rejecting passthrough '$a' â€” '-l' is broken for this purpose; that's why this skill exists. See SKILL.md." ;;
    -x|--remote) die "rejecting passthrough '$a' â€” for remote Chronos runs use the sapphire-e2e-test skill." ;;
  esac
done

export NO_ENV_STRIP
# Re-exec under env -i if AI-agent vars are present (skip if --no-env-strip).
maybe_reexec_clean "$sub" "-n" "$ns" "-f" "$sql" \
  ${jpkg:+-j "$jpkg"} ${cpkg:+-c "$cpkg"} ${tag:+-g "$tag"} \
  --log-dir "$log_dir" ${dryrun:+--dry-run} \
  ${NO_ENV_STRIP:+--no-env-strip} \
  "$@"

# Defaults by engine.
ts="$(date +%Y%m%d_%H%M%S)"
case "$sub" in
  velox)
    [[ -n "$cpkg" ]] || cpkg="prestissimo-deployed"
    [[ -n "$tag"  ]] || tag="SAPPHIRE_VELOX_SPARK3"
    log="${log_dir}/sapphire_local_velox_${ts}.log"
    run_engine "velox" "$ns" "$sql" "$jpkg" "$cpkg" "$tag" "$log" "$dryrun" "$@"
    exit $?
    ;;
  java)
    # No -c â†’ Java-only execution.
    cpkg=""
    log="${log_dir}/sapphire_local_java_${ts}.log"
    run_engine "java" "$ns" "$sql" "$jpkg" "$cpkg" "$tag" "$log" "$dryrun" "$@"
    exit $?
    ;;
  ab)
    # Run Java first (typically the control), then Velox (the test).
    log_java="${log_dir}/sapphire_local_java_${ts}.log"
    log_velox="${log_dir}/sapphire_local_velox_${ts}.log"

    echo "########## sapphire-local ab: JAVA leg ##########"
    run_engine "java"  "$ns" "$sql" "$jpkg" "" "$tag" "$log_java" "$dryrun" "$@"
    rc_java=$?

    echo
    echo "########## sapphire-local ab: VELOX leg ##########"
    velox_cpkg="${cpkg:-prestissimo-deployed}"
    velox_tag="${tag:-SAPPHIRE_VELOX_SPARK3}"
    run_engine "velox" "$ns" "$sql" "$jpkg" "$velox_cpkg" "$velox_tag" "$log_velox" "$dryrun" "$@"
    rc_velox=$?

    echo
    echo "########## sapphire-local ab: SUMMARY ##########"
    echo "Java  log: $log_java  (EXIT=$rc_java)"
    echo "Velox log: $log_velox (EXIT=$rc_velox)"
    echo
    # Extract numeric counts (single-column scalar case) and diff if possible.
    java_val="$(grep -aA1 '^Rows: 1$' "$log_java"  2>/dev/null | tail -1 | grep -oE '\[-?[0-9]+\]' | tr -d '[]' || true)"
    velox_val="$(grep -aA1 '^Rows: 1$' "$log_velox" 2>/dev/null | tail -1 | grep -oE '\[-?[0-9]+\]' | tr -d '[]' || true)"
    if [[ -n "$java_val" && -n "$velox_val" ]]; then
      echo "Java  result: $java_val"
      echo "Velox result: $velox_val"
      echo "DIFF (Java - Velox): $((java_val - velox_val))"
    else
      echo "Could not extract single-scalar result from both logs; inspect with 'sapphire-local extract <log>'."
    fi
    # Overall exit = nonzero if either leg failed.
    [[ "$rc_java" -eq 0 && "$rc_velox" -eq 0 ]]
    exit $?
    ;;
esac
