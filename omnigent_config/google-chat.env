# Personal, non-secret Google Chat bridge policy. init.sh materializes this as
# ~/.config/omnigent-google-chat.env only on the Omnigent hub.
OMNIGENT_GCHAT_SPACE=spaces/AAQApOLnDgY
OMNIGENT_GCHAT_ALLOWED_ACTOR_ID=users/102195242951244666483
OMNIGENT_GCHAT_META_BOT_ACTOR_ID=users/109437034995932983843
OMNIGENT_GCHAT_MENTION_UNIXNAME=mkarrmann
OMNIGENT_GCHAT_PHASE0_VALIDATED=true

# The hub's server is the transcript authority for every registered Mac and
# devserver host. Mirror recent sessions from all of those hosts by default.
OMNIGENT_GCHAT_HOST_SCOPE=all
OMNIGENT_GCHAT_DISCOVERY=host-active
OMNIGENT_GCHAT_LABEL=omnigent.google_chat.enabled

OMNIGENT_GCHAT_DATABASE=~/.omnigent/google-chat.sqlite3
OMNIGENT_GCHAT_MIRROR_MODE=concise
OMNIGENT_GCHAT_MENTION_ON_ROOT=true
OMNIGENT_GCHAT_MENTION_ON_COMPLETION=false
OMNIGENT_GCHAT_SESSION_LOOKBACK_HOURS=24
OMNIGENT_GCHAT_MAX_MESSAGE_CHARS=12000
OMNIGENT_GCHAT_MAX_SESSION_CHARS=100000
OMNIGENT_GCHAT_MAX_INPUT_CHARS=12000
OMNIGENT_GCHAT_ACTIVE_POLL_SECONDS=10
OMNIGENT_GCHAT_IDLE_POLL_SECONDS=30
OMNIGENT_GCHAT_POLL_OVERLAP_SECONDS=120
OMNIGENT_GCHAT_HEALTH_STALE_SECONDS=120
OMNIGENT_GCHAT_RECENT_ACTIVE_SECONDS=120
OMNIGENT_GCHAT_CLI_TIMEOUT_SECONDS=90
META_CLI=/usr/local/bin/meta
LOG_LEVEL=INFO
