#!/bin/bash
# Wrapper that exec's the dvsc-core-acp ACP server. Mirrors
# ~/dotfiles/bin/claude-agent-acp's structure so that the broker's
# `--declare-agent cmd=...` can point at a stable shell entry point
# regardless of which fbsource checkout currently has the source
# materialized.
#
# Resolution order for the dist entry point:
#   1. $DVSC_ACP_DIST (explicit override)
#   2. ~/checkout1/fbsource/users/mk/mkarrmann/dvsc-core-acp/.../dist/index.js
#   3. ~/checkout2/fbsource/...
#   4. ~/checkout3/fbsource/...
#   5. ~/checkout4/fbsource/...
#   6. ~/fbsource/users/mk/mkarrmann/dvsc-core-acp/.../dist/index.js
#
# Each candidate is checked for existence; the first hit wins.

set -euo pipefail

# Stderr is teed to a fixed log so that JSON-RPC traffic on stdout stays
# clean. Inspect ~/.cache/dvsc-core-acp.log if a session fails to start.
exec 2> >(tee -a "$HOME/.cache/dvsc-core-acp.log" >&2)
echo "=== dvsc-core-acp wrapper start: $(date -Iseconds) pid=$$ ===" >&2

readonly DIST_REL="users/mk/mkarrmann/dvsc-core-acp/packages/acp-wrapper/dist/index.js"

resolve_dist() {
  if [[ -n "${DVSC_ACP_DIST:-}" ]]; then
    if [[ -f "$DVSC_ACP_DIST" ]]; then
      echo "$DVSC_ACP_DIST"
      return 0
    fi
    echo "DVSC_ACP_DIST=$DVSC_ACP_DIST set but not a file" >&2
    return 1
  fi
  local candidate
  for root in \
    "$HOME/checkout1/fbsource" \
    "$HOME/checkout2/fbsource" \
    "$HOME/checkout3/fbsource" \
    "$HOME/checkout4/fbsource" \
    "$HOME/fbsource"; do
    candidate="$root/$DIST_REL"
    if [[ -f "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

if ! SCRIPT="$(resolve_dist)"; then
  echo "dvsc-core-acp dist not found. Build it with:" >&2
  echo "  cd ~/fbsource/users/mk/mkarrmann/dvsc-core-acp && npx tsc -b" >&2
  echo "Or set DVSC_ACP_DIST to the absolute path of dist/index.js." >&2
  exit 1
fi

NODE=""
for candidate in \
  "${DVSC_ACP_NODE:-}" \
  "$HOME/.local/share/node/bin/node" \
  "$(find "$HOME/.cache/dotslash" -name node -type f 2>/dev/null | head -1)" \
  "$(command -v node 2>/dev/null || true)"; do
  [[ -n "$candidate" && -x "$candidate" ]] || continue
  major="$("$candidate" -e 'process.stdout.write(String(process.versions.node.split(".")[0]))' 2>/dev/null || echo 0)"
  if [[ "$major" =~ ^[0-9]+$ ]] && (( major >= 18 )); then
    NODE="$candidate"
    break
  fi
done
if [[ -z "$NODE" ]]; then
  echo "no Node 18+ binary found. Checked: \$DVSC_ACP_NODE, ~/.local/share/node/bin/node, ~/.cache/dotslash, PATH." >&2
  echo "Install one with: cp ~/fbsource/xplat/third-party/node/bin/node-linux-x64 ~/.local/share/node/bin/node" >&2
  exit 1
fi

# Defensive default for broker-spawned wrappers: the broker may have been
# started from an environment that did not source ~/.localrc.
export DM_AUTOCOMPACT_PCT_OVERRIDE="${DM_AUTOCOMPACT_PCT_OVERRIDE:-99}"
# Likewise, keep dvsc-core in no-approval mode unless explicitly overridden.
export DVSC_AUTO_RUN_MODE="${DVSC_AUTO_RUN_MODE:-autoRunAll}"

echo "node=$NODE script=$SCRIPT DM_AUTOCOMPACT_PCT_OVERRIDE=$DM_AUTOCOMPACT_PCT_OVERRIDE DVSC_AUTO_RUN_MODE=$DVSC_AUTO_RUN_MODE" >&2
echo "=== begin dvsc-core-acp output ===" >&2

exec "$NODE" "$SCRIPT" "$@"
