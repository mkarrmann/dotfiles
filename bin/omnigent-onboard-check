#!/usr/bin/env bash
# Verify that init.sh converged this Linux machine to its declared Omnigent role.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$DOTFILES/bin/omnigent-server-url}"
HUB_BIN="${OMNIGENT_HUB_BIN:-$DOTFILES/bin/omnigent-hub}"
local_fqdn="${OMNIGENT_LOCAL_FQDN:-$(hostname -f 2>/dev/null || hostname)}"

[[ "$(uname -s)" == Linux ]] || exit 0

url="$($SERVER_URL_BIN)"
curl -sf --noproxy '*' --max-time 5 "$url/health" >/dev/null
systemctl --user is-active --quiet omnigent-host.service

# Exercise one real request over the host WebSocket. The host list's `online`
# flag only proves that a socket was accepted; this RPC proves bidirectional
# request/response delivery, which runner launch also requires.
ONBOARD_URL="$url" ONBOARD_FQDN="$local_fqdn" python3 - <<'PY'
import json
import os
import urllib.parse
import urllib.request

base = os.environ["ONBOARD_URL"].rstrip("/")
fqdn = os.environ["ONBOARD_FQDN"]
opener = urllib.request.build_opener(urllib.request.ProxyHandler({}))
with opener.open(f"{base}/v1/hosts", timeout=5) as response:
    payload = json.load(response)
hosts = payload.get("hosts") if isinstance(payload, dict) else None
if not isinstance(hosts, list):
    raise SystemExit("Omnigent host list returned an invalid payload")
matches = [host for host in hosts if isinstance(host, dict) and host.get("name") == fqdn]
if len(matches) != 1 or matches[0].get("status") != "online":
    raise SystemExit(f"execution host {fqdn!r} is not uniquely online")
host_id = matches[0].get("host_id")
if not isinstance(host_id, str) or not host_id:
    raise SystemExit(f"execution host {fqdn!r} has no host id")
path = urllib.parse.quote(host_id, safe="")
with opener.open(f"{base}/v1/hosts/{path}/filesystem?limit=1", timeout=10) as response:
    result = json.load(response)
if not isinstance(result, dict) or not isinstance(result.get("data"), list):
    raise SystemExit(f"execution host {fqdn!r} RPC returned an invalid payload")
PY

if "$SERVER_URL_BIN" --is-candidate; then
  status="$($HUB_BIN local-status --json)"
  STATUS_JSON="$status" python3 - "$local_fqdn" <<'PY'
import json
import os
import sys

status = json.loads(os.environ["STATUS_JSON"])
local_fqdn = sys.argv[1]
record = status.get("record")
services = status.get("services")
gate = status.get("gate")
if not isinstance(record, dict) or record.get("state") != "active":
    raise SystemExit("shared active-hub record is unavailable or fenced")
if not isinstance(services, dict) or not isinstance(gate, dict):
    raise SystemExit("local hub status is incomplete")

active = record.get("active_hub") == local_fqdn
required = (
    {
        "omnigent-server.service",
        "omnigent-google-chat.service",
        "omnigent-snapshot.timer",
    }
    if active
    else {"omnigent-client-proxy.service"}
)
for service in required:
    if services.get(service) != "active":
        raise SystemExit(f"{service} is {services.get(service)!r}, expected 'active'")
if services.get("omnigent-host.service") != "active":
    raise SystemExit("omnigent-host.service is not active")
if (gate.get("allowed") is True) != active:
    raise SystemExit("startup gate does not match this candidate's role")
forbidden = (
    {"omnigent-client-proxy.service", "omnigent-prodnet.service"}
    if active
    else {
        "omnigent-server.service",
        "omnigent-prodnet.service",
        "omnigent-google-chat.service",
        "omnigent-snapshot.timer",
    }
)
for service in forbidden:
    if services.get(service) == "active":
        raise SystemExit(f"{service} must be inactive for this role")
PY
else
  systemctl --user is-active --quiet omnigent-client-proxy.service
fi

echo "[omnigent-onboard] healthy on $local_fqdn via $url"
