#!/usr/bin/env bash
# Materialize the tracked personal Google Chat policy as a private runtime env
# on the one devserver that owns the central Omnigent server.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
POLICY="${OMNIGENT_GCHAT_POLICY_FILE:-$DOTFILES/omnigent_config/google-chat.env}"
CONFIG_HOME="${OMNIGENT_GCHAT_CONFIG_HOME:-$HOME/.config}"
RUNTIME_ENV="${OMNIGENT_GCHAT_RUNTIME_ENV:-$CONFIG_HOME/omnigent-google-chat.env}"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$DOTFILES/bin/omnigent-server-url}"

if ! "$SERVER_URL_BIN" --is-hub; then
  printf '[omnigent-gchat] not the configured hub; runtime bridge config is not installed\n'
  exit 0
fi

if [[ ! -f "$POLICY" ]]; then
  printf 'ERROR: tracked Google Chat policy is missing: %s\n' "$POLICY" >&2
  exit 1
fi

mkdir -p "$CONFIG_HOME"
tmp="$(mktemp "$RUNTIME_ENV.tmp.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
{
  printf '# Generated by ~/dotfiles/bin/omnigent-google-chat-ensure; do not edit.\n'
  printf '# Update ~/dotfiles/omnigent_config/google-chat.env and rerun ~/dotfiles/init.sh.\n'
  printf 'OMNIGENT_BASE_URL=%s\n\n' "$("$SERVER_URL_BIN")"
  cat "$POLICY"
} > "$tmp"
chmod 600 "$tmp"

if [[ -f "$RUNTIME_ENV" ]] && cmp -s "$tmp" "$RUNTIME_ENV"; then
  rm -f "$tmp"
  chmod 600 "$RUNTIME_ENV"
  printf '[omnigent-gchat] runtime config already current: %s\n' "$RUNTIME_ENV"
else
  mv -f "$tmp" "$RUNTIME_ENV"
  printf '[omnigent-gchat] generated private runtime config: %s\n' "$RUNTIME_ENV"
fi
trap - EXIT
