#!/usr/bin/env bash
# Candidate hubs reconcile ownership; ordinary devservers only refresh their
# route and execution host against the candidates.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$DOTFILES/bin/omnigent-server-url}"
HUB_BIN="${OMNIGENT_HUB_BIN:-$DOTFILES/bin/omnigent-hub}"

if "$SERVER_URL_BIN" --is-candidate; then
  exec "$HUB_BIN" reconcile-services --json
fi

"$HUB_BIN" discover --json >/dev/null
exec "$HUB_BIN" route-ensure --restart-host --json
