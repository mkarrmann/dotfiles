#!/usr/bin/env bash
# Candidate hubs reconcile ownership from Persistent Storage. Ordinary
# devservers first discover that ownership through the candidates, then use
# the same reconciliation path to maintain their local SSH client tunnel.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$DOTFILES/bin/omnigent-server-url}"
HUB_BIN="${OMNIGENT_HUB_BIN:-$DOTFILES/services/omnigent-hub/.venv/bin/omnigent-hub}"

if "$SERVER_URL_BIN" --is-candidate; then
  exec "$HUB_BIN" reconcile-services --json
fi

"$HUB_BIN" discover --json >/dev/null
exec "$HUB_BIN" reconcile-services --json
