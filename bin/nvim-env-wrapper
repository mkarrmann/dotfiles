#!/bin/bash
# Neovim wrapper that handles environment-specific issues
# This wrapper auto-detects the environment and applies necessary workarounds

# Meta environment detection and fixes
if [[ "$http_proxy" == *"fwdproxy"* ]] || [[ -n "$THRIFT_TLS_CL_CERT_PATH" ]]; then
    # At Meta - clear conflicting certificate variables to prevent OpenSSL segfaults
    unset THRIFT_TLS_CL_CERT_PATH
    unset THRIFT_TLS_CL_KEY_PATH
    unset CLAUDE_CODE_CLIENT_CERT
    unset CODEX_OTEL_CLIENT_CERT
    unset OTEL_EXPORTER_OTLP_METRICS_CLIENT_CERTIFICATE
fi

# Add more environment-specific fixes here as needed
# if [[ -n "$SOME_COMPANY_VAR" ]]; then
#     # Company-specific fixes
# fi

# Find the real nvim, skipping this wrapper's own directory to avoid recursion
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REAL_NVIM=""
IFS=: read -ra _path_dirs <<< "$PATH"
for _dir in "${_path_dirs[@]}"; do
    [[ "$_dir" == "$SCRIPT_DIR" ]] && continue
    if [[ -x "$_dir/nvim" ]]; then
        REAL_NVIM="$_dir/nvim"
        break
    fi
done
if [[ -z "$REAL_NVIM" ]]; then
    echo "nvim-env-wrapper: nvim not found in PATH" >&2
    exit 1
fi
exec "$REAL_NVIM" "$@"