#!/usr/bin/env bash
# Idempotently ensure one acp-broker is running on this devvm.
#
# Called from nvs-tunnels' remote_cmd at each ET (re)connect. If the
# broker is already up (PID alive, UDS present), this is a no-op.
# Otherwise it spawns one — under setsid so it survives ET teardown
# the same way headless nvim does (see ~/dotfiles/bin/nvs).
#
# Persistence routes to the Mac via the reverse tunnel established by
# nvs-tunnels (-r 7847:7847 → ACP_BROKER_SQLITE_PERSISTENCE_ADDR).
# Upstream agent comes from $ACP_BROKER_UPSTREAM_AGENT (default:
# whatever `command -v claude-agent-acp` finds on PATH).
#
# See acp-broker docs/RUNBOOK.md §3.3 for the broader recipe.
set -euo pipefail

PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/acp-broker.pid"
SOCKET="${XDG_RUNTIME_DIR:-/tmp}/acp-broker.sock"
LOGDIR="${XDG_STATE_HOME:-$HOME/.local/state}/acp-broker"
LOGFILE="$LOGDIR/server.log"
BROKER_ID="${ACP_BROKER_ID:-$(hostname -s)}"
PERSISTENCE_ADDR="${ACP_BROKER_SQLITE_PERSISTENCE_ADDR:-127.0.0.1:7847}"

# Resolve the upstream agent. Letting the operator override via env
# keeps this script agent-agnostic (acp-broker doesn't care which
# agent it fronts).
UPSTREAM_AGENT="${ACP_BROKER_UPSTREAM_AGENT:-$(command -v claude-agent-acp 2>/dev/null || true)}"
if [[ -z "$UPSTREAM_AGENT" ]]; then
  echo "acp-broker-up: ACP_BROKER_UPSTREAM_AGENT unset and no claude-agent-acp on PATH" >&2
  exit 1
fi

mkdir -p "$LOGDIR"

# Already up? PID alive AND socket bound — guards against the case
# where a prior broker died but left a stale socket file behind.
if [[ -S "$SOCKET" ]] && [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  exit 0
fi
rm -f "$SOCKET" "$PIDFILE"

# setsid (not nohup): see ~/dotfiles/bin/nvs for the rationale —
# nohup only ignores SIGHUP, but ET will SIGTERM/SIGKILL the whole
# process group on session teardown. setsid moves the broker into
# its own session so it survives.
ACP_BROKER_ID="$BROKER_ID" \
ACP_BROKER_SQLITE_PERSISTENCE_ADDR="$PERSISTENCE_ADDR" \
setsid acp-broker "$UPSTREAM_AGENT" \
  --socket "$SOCKET" \
  --per-session-agents \
  >>"$LOGFILE" 2>&1 </dev/null &

echo $! > "$PIDFILE"
echo "acp-broker-up: PID=$(cat "$PIDFILE") socket=$SOCKET broker_id=$BROKER_ID upstream=$UPSTREAM_AGENT"
