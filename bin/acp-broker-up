#!/usr/bin/env bash
# Idempotently ensure the per-devvm acp-broker is running.
#
# The broker runs as a systemd --user unit (authoritative copy at
# ~/dotfiles/systemd/acp-broker.service, symlinked into
# ~/.config/systemd/user/ by ~/dotfiles/init.sh). With user lingering
# enabled (loginctl enable-linger mkarrmann), the unit auto-starts at
# boot and survives logout — this script is just a safety-net kick for
# the rare case where it was disabled or systemd hit its restart burst
# limit.
set -euo pipefail
exec systemctl --user start acp-broker.service
