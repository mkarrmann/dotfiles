#!/usr/bin/env bash
set -euo pipefail

# ── Workspace definitions ────────────────────────────────────────────
# Format: title|workdir|command
# Desktop 1 is reserved as a general-purpose desktop.
# Workspaces are placed on Desktops 2..N+1 in array order.
WORKSPACES=(
  "Local MacOS|~|tmux new-session -A -s macos1"
  "FTW: main1|~|x2ssh -et devvm36111.ftw0.facebook.com -c 'zsh -lc \"tmux new-session -A -s main1\"'"
  "FTW: fbsource1|~|x2ssh -et devvm36111.ftw0.facebook.com -c 'zsh -lc \"tmux new-session -A -s fbsource1 -c ~/fbsource\"'"
  "FTW: fbsource2|~|x2ssh -et devvm36111.ftw0.facebook.com -c 'zsh -lc \"tmux new-session -A -s fbsource2 -c ~/fbsource2\"'"
  "CCO: main1|~|x2ssh -et devvm20365.cco0.facebook.com -c 'zsh -lc \"tmux new-session -A -s main1\"'"
  "CCO: fbsource1|~|x2ssh -et devvm20365.cco0.facebook.com -c 'zsh -lc \"tmux new-session -A -s fbsource1 -c ~/fbsource\"'"
  "CCO: fbsource2|~|x2ssh -et devvm20365.cco0.facebook.com -c 'zsh -lc \"tmux new-session -A -s fbsource2 -c ~/fbsource2\"'"
)
# ─────────────────────────────────────────────────────────────────────

window_exists() {
  local result
  result=$(osascript \
    -e 'on run argv' \
    -e '  tell application "Ghostty"' \
    -e '    if (name of every window) contains (item 1 of argv) then' \
    -e '      return "true"' \
    -e '    end if' \
    -e '  end tell' \
    -e 'end run' \
    -- "$1" 2>/dev/null) || return 1
  [[ "$result" == "true" ]]
}

create_window() {
  local title="$1" workdir="$2" cmd="$3"
  workdir="${workdir/#\~/$HOME}"
  osascript \
    -e 'on run argv' \
    -e '  set theTitle to item 1 of argv' \
    -e '  set theWorkdir to item 2 of argv' \
    -e '  set theCmd to item 3 of argv' \
    -e '  set titleSeq to "printf '\''\\033]0;%s\\007'\'' " & quoted form of theTitle & " && exec " & theCmd' \
    -e '  tell application "Ghostty"' \
    -e '    set cfg to new surface configuration' \
    -e '    set command of cfg to "zsh -lic " & quoted form of titleSeq' \
    -e '    set initial working directory of cfg to theWorkdir' \
    -e '    set wait after command of cfg to true' \
    -e '    set environment variables of cfg to {"GHOSTTY_WORKSPACE_TITLE=" & theTitle}' \
    -e '    new window with configuration cfg' \
    -e '  end tell' \
    -e 'end run' \
    -- "$title" "$workdir" "$cmd"
}

hs_eval() {
  hs -c "$1" 2>/dev/null | grep -v '^--' | tr -d '[:space:]'
}

if ! command -v hs &>/dev/null; then
  echo "ERROR: Hammerspoon CLI (hs) not found." >&2
  echo "Ensure Hammerspoon is running and has loaded hs.ipc (restart it after init.sh)." >&2
  exit 1
fi

# Capture the current screen for all subsequent space operations.
# Uses mainScreen() (screen with current focus) but locks it in so it
# doesn't drift as windows are created on other screens.
hs_eval "return ghosttyInitScreen()" >/dev/null

# If Ghostty isn't running, launch it and close the default window it opens
if ! osascript -e 'application "Ghostty" is running' 2>/dev/null | grep -q 'true'; then
  open -a Ghostty
  sleep 2
  osascript -e 'tell application "Ghostty" to close window 1' 2>/dev/null || true
fi

total=${#WORKSPACES[@]}

echo "Ensuring $((total + 1)) macOS Spaces exist (1 general + ${total} workspaces)..."
added=$(hs_eval "return tostring(ghosttyEnsureSpaces($((total + 1))))")
if [[ "$added" == "-1" ]]; then
  echo "ERROR: Failed to ensure spaces. Is Hammerspoon running with the workspace config loaded?" >&2
  exit 1
elif [[ "$added" != "0" ]]; then
  echo "Created ${added} new Space(s). Waiting for Mission Control to settle..."
  sleep 1.5
fi

failures=0
swept=0
max_sweeps=15

for i in "${!WORKSPACES[@]}"; do
  IFS='|' read -r title workdir cmd <<< "${WORKSPACES[$i]}"
  space=$((i + 2))

  echo "[$title] switching to Desktop ${space}..."
  result=$(hs_eval "return ghosttyGotoSpace(${space})")
  if [[ "$result" != "ok" ]]; then
    echo "WARNING: [$title] failed to switch to Desktop ${space}: ${result}" >&2
    ((failures++)) || true
    continue
  fi
  sleep 0.7

  # Sweep non-Ghostty windows from this desktop to Desktop 1
  prev_result=""
  for attempt in $(seq 1 5); do
    if [[ "$swept" -ge "$max_sweeps" ]]; then break; fi
    result=$(hs_eval "return ghosttySweepFocused()")
    case "$result" in
      empty|ghostty|other_screen) break ;;
      swept:*)
        if [[ "$result" == "$prev_result" ]]; then
          echo "WARNING: Window on Desktop $space could not be moved, skipping" >&2
          break
        fi
        echo "Swept window from Desktop $space to Desktop 1"
        ((swept++)) || true
        prev_result="$result"
        sleep 0.7
        hs_eval "return ghosttyGotoSpace($space)" >/dev/null
        sleep 0.7
        ;;
      *) break ;;
    esac
  done

  if window_exists "$title"; then
    echo "[$title] already exists, skipping"
    continue
  fi

  echo "[$title] creating..."
  hs_eval "return ghosttyGotoSpace(${space})" >/dev/null
  sleep 0.5
  if ! create_window "$title" "$workdir" "$cmd"; then
    echo "WARNING: [$title] creation failed, skipping" >&2
    ((failures++)) || true
    continue
  fi
  sleep 0.7
  hs_eval "return ghosttyThrowToSpace(${space})" >/dev/null
  sleep 0.5
done

if [[ "$swept" -gt 0 ]]; then
  echo "Swept ${swept} window(s) to Desktop 1."
fi

# TODO: Fix positions of existing workspace windows that have been moved to the
# wrong desktop. Blocked by hs.spaces.windowSpaces() being broken on macOS 26.
# The sweep above handles non-Ghostty windows; repositioning Ghostty workspace
# windows requires a working way to query which space a window is on.

# Switch back to Desktop 1
hs_eval "return ghosttyGotoSpace(1)" >/dev/null 2>&1 || true

if [[ "$failures" -gt 0 ]]; then
  echo "Done with ${failures} warning(s)."
else
  echo "Done."
fi
