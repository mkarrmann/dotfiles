#!/usr/bin/env bash
# Give every non-active Linux client a resilient, stable loopback URL for the
# active hub's loopback-only Omnigent server.
#
# This resolves the active hub and hands off to omnigent_hub.client_proxy, which
# owns 127.0.0.1:<port> persistently and relays to a private backend port fed by
# a supervised, self-healing SSH tunnel. Decoupling the listening socket from the
# SSH connection keeps the endpoint alive across tunnel flaps, so an in-flight
# agent turn survives a blip instead of dying with runner_disconnected.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$DOTFILES/bin/omnigent-server-url}"
SSH_BIN="${OMNIGENT_SSH_BIN:-/usr/bin/ssh}"
PYTHON="${OMNIGENT_HUB_PYTHON:-$DOTFILES/services/omnigent-hub/.venv/bin/python}"
target="$($SERVER_URL_BIN --hub)"
port="$($SERVER_URL_BIN --port)"
backend_port="${OMNIGENT_CLIENT_BACKEND_PORT:-6768}"
local_fqdn="${OMNIGENT_LOCAL_FQDN:-$(hostname -f 2>/dev/null || hostname)}"

if [[ "$target" == "$local_fqdn" ]]; then
  echo "ERROR: refusing to proxy the active hub to itself: $target" >&2
  exit 1
fi

exec "$PYTHON" -m omnigent_hub.client_proxy \
  --hub "$target" \
  --server-port "$port" \
  --backend-port "$backend_port" \
  --ssh-bin "$SSH_BIN"
