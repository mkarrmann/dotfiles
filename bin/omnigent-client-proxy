#!/usr/bin/env bash
# Give every non-active Linux client a stable loopback URL by forwarding it
# over SSH to the active hub's loopback-only Omnigent server.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$DOTFILES/bin/omnigent-server-url}"
SSH_BIN="${OMNIGENT_SSH_BIN:-/usr/bin/ssh}"
target="$($SERVER_URL_BIN --hub)"
port="$($SERVER_URL_BIN --port)"
local_fqdn="${OMNIGENT_LOCAL_FQDN:-$(hostname -f 2>/dev/null || hostname)}"

if [[ "$target" == "$local_fqdn" ]]; then
  echo "ERROR: refusing to proxy the active hub to itself: $target" >&2
  exit 1
fi

# ClearAllForwardings would also discard the command-line -L below.
exec "$SSH_BIN" \
  -o BatchMode=yes \
  -o ConnectTimeout=10 \
  -o ConnectionAttempts=3 \
  -o ExitOnForwardFailure=yes \
  -o ServerAliveInterval=15 \
  -o ServerAliveCountMax=3 \
  -N \
  -L "127.0.0.1:${port}:127.0.0.1:${port}" \
  "$target"
