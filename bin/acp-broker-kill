#!/usr/bin/env bash
# Stop or restart the per-devvm acp-broker (systemd --user unit; see
# ~/dotfiles/systemd/acp-broker.service).
#
# Usage:
#   acp-broker-kill              stop the broker (will NOT auto-restart;
#                                systemctl stop suppresses Restart=)
#   acp-broker-kill -r|--restart restart in place
#   acp-broker-kill -h|--help    show usage
set -euo pipefail

case "${1:-}" in
  "")            exec systemctl --user stop acp-broker.service ;;
  -r|--restart)  exec systemctl --user restart acp-broker.service ;;
  -h|--help)     sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//' ; exit 0 ;;
  *)             echo "acp-broker-kill: unknown arg: $1" >&2 ; exit 2 ;;
esac
