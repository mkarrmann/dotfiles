#!/usr/bin/env bash
# Rename the workspace parent dirs in place:
#   ~/main    -> ~/checkout1
#   ~/scratch -> ~/checkout2
#
# Uses 'eden unmount' + mv + config.json patch + 'eden mount' instead of
# eden rm + fbclone, so working-copy state, drafts, shelves, and freshly
# rebuilt buck-out caches survive. Bind redirections are recreated at the
# new path via 'eden redirect fixup'.
#
# Idempotent: re-running after success is a no-op.
#
# Usage:
#   rename-checkouts [--dry-run]
#                    [--from-primary OLD] [--to-primary NEW]
#                    [--from-secondary OLD] [--to-secondary NEW]

set -euo pipefail

FROM_PRIMARY="main"
TO_PRIMARY="checkout1"
FROM_SECONDARY="scratch"
TO_SECONDARY="checkout2"
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)         DRY_RUN=1; shift ;;
    --from-primary)    FROM_PRIMARY="$2"; shift 2 ;;
    --to-primary)      TO_PRIMARY="$2"; shift 2 ;;
    --from-secondary)  FROM_SECONDARY="$2"; shift 2 ;;
    --to-secondary)    TO_SECONDARY="$2"; shift 2 ;;
    -h|--help)         sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

LOG_DIR="$HOME/rename-checkouts-$(date +%Y%m%d-%H%M%S)"
EDEN_CONFIG="$HOME/local/.eden/config.json"

log()  { printf '\n=== %s ===\n' "$*"; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
die()  { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
run()  { echo "+ $*"; if (( ! DRY_RUN )); then "$@"; fi; }

# ── Preflight ───────────────────────────────────────────────────────
mkdir -p "$LOG_DIR"
log "Rename log: $LOG_DIR"
echo "Hostname: $(hostname)"
echo "$HOME/$FROM_PRIMARY   -> $HOME/$TO_PRIMARY"
echo "$HOME/$FROM_SECONDARY -> $HOME/$TO_SECONDARY"
(( DRY_RUN )) && echo "Mode: DRY RUN — no changes will be made"

cd "$HOME"

for cmd in eden python3 watchman; do
  command -v "$cmd" >/dev/null || warn "$cmd not on PATH"
done

[[ -f "$EDEN_CONFIG" ]] || die "Eden config not found at $EDEN_CONFIG"

# Build list of (old_mount_path, new_mount_path) pairs for both fbsource
# and configerator under each workspace.
declare -a OLD_MOUNTS=()
declare -a NEW_MOUNTS=()
for pair in "$FROM_PRIMARY:$TO_PRIMARY" "$FROM_SECONDARY:$TO_SECONDARY"; do
  old_ws="${pair%:*}"
  new_ws="${pair#*:}"
  for kind in fbsource configerator; do
    old="$HOME/$old_ws/$kind"
    new="$HOME/$new_ws/$kind"
    if [[ -d "$old" ]]; then
      OLD_MOUNTS+=("$old")
      NEW_MOUNTS+=("$new")
    elif [[ -d "$new" ]]; then
      echo "  $new already exists — skipping (looks like rename already done)"
    else
      warn "Neither $old nor $new exists; skipping"
    fi
  done
done

if (( ${#OLD_MOUNTS[@]} == 0 )); then
  log "Nothing to rename. Exiting."
  exit 0
fi

# Refuse to run if cwd is inside any path we'll touch.
for old in "${OLD_MOUNTS[@]}"; do
  case "$PWD/" in "$old"/*|"$old/") die "cwd $PWD is inside $old. cd ~ and re-run." ;; esac
done
case "$PWD/" in
  "$HOME/$FROM_PRIMARY"/*|"$HOME/$FROM_PRIMARY/"|"$HOME/$FROM_SECONDARY"/*|"$HOME/$FROM_SECONDARY/")
    die "cwd $PWD is inside an in-scope workspace. cd ~ and re-run." ;;
esac

# Verify each old mount is actually an Eden mount (basic sanity).
for old in "${OLD_MOUNTS[@]}"; do
  [[ -L "$old/.eden/root" ]] || die "$old does not look like an Eden mount (no .eden/root)"
done

# ── Phase 1: Inventory ──────────────────────────────────────────────
log "Phase 1: Inventory"
echo "Mounts to rename:"
for i in "${!OLD_MOUNTS[@]}"; do
  echo "  ${OLD_MOUNTS[$i]} -> ${NEW_MOUNTS[$i]}"
done | tee "$LOG_DIR/plan.txt"

cp -a "$EDEN_CONFIG" "$LOG_DIR/config.json.bak"
echo "Eden config backup: $LOG_DIR/config.json.bak"

# Snapshot redirections so we have a record before fixup.
for old in "${OLD_MOUNTS[@]}"; do
  printf '\n=== %s ===\n' "$old" >> "$LOG_DIR/redirects-pre.txt"
  eden redirect list --mount "$old" >> "$LOG_DIR/redirects-pre.txt" 2>&1 || true
done

# ── Phase 2: Free busy mounts ───────────────────────────────────────
log "Phase 2: Free busy processes"

# Kill watchdogs first so they don't respawn the nvim servers.
mapfile -t watchdog_pids < <(pgrep -u "$USER" -f 'nvs --server-only' 2>/dev/null || true)
for pid in "${watchdog_pids[@]}"; do
  [[ -z "$pid" ]] && continue
  echo "  killing nvs watchdog pid $pid"
  (( DRY_RUN )) || kill "$pid" 2>/dev/null || true
done

# Kill any nvim --headless whose cwd is inside an in-scope mount.
mapfile -t headless_pids < <(pgrep -u "$USER" -f 'nvim --headless --listen' 2>/dev/null || true)
for pid in "${headless_pids[@]}"; do
  cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null || true)
  for old in "${OLD_MOUNTS[@]}" "$HOME/$FROM_PRIMARY" "$HOME/$FROM_SECONDARY"; do
    case "$cwd" in
      "$old"|"$old"/*)
        echo "  killing nvim pid $pid (cwd $cwd)"
        (( DRY_RUN )) || kill "$pid" 2>/dev/null || true
        break ;;
    esac
  done
done

(( ! DRY_RUN )) && sleep 1

# Final busy check.
busy=""
for old in "${OLD_MOUNTS[@]}"; do
  for pid_dir in /proc/[0-9]*; do
    pid=$(basename "$pid_dir")
    cwd=$(readlink "$pid_dir/cwd" 2>/dev/null || true)
    case "$cwd" in
      "$old"|"$old"/*)
        comm=$(cat "$pid_dir/comm" 2>/dev/null || echo "?")
        busy+="    $pid  $comm  (cwd: $cwd)"$'\n'
        ;;
    esac
  done
done
if [[ -n "$busy" ]]; then
  echo "$busy"
  cat >&2 <<EOF
ERROR: Processes above hold cwd inside in-scope mounts. They will block
'eden unmount'.

Most are likely devmate-managed (mux, devai_server, www_mcp_server,
srconveyor, buck2-daemon). Stop them with:

    devmate stop

Then re-run this script. Anything else (your own shells, editors, etc.)
must be exited manually.
EOF
  exit 1
fi
echo "  no busy processes"

# ── Phase 3: Confirm ────────────────────────────────────────────────
log "Phase 3: Confirm"
if (( DRY_RUN )); then
  echo "(dry run — would proceed)"
else
  read -rp "Proceed with rename? [type 'yes' to proceed]: " ans
  [[ "$ans" == "yes" ]] || die "Aborted by user."
fi

# ── Phase 4: Unmount ────────────────────────────────────────────────
log "Phase 4: eden unmount"
for old in "${OLD_MOUNTS[@]}"; do
  if [[ -L "$old/.eden/root" ]]; then
    run eden unmount "$old" || warn "unmount of $old failed"
  else
    echo "  $old already unmounted — skipping"
  fi
done

# ── Phase 5: Move parent dirs ───────────────────────────────────────
log "Phase 5: mv workspace dirs"
for pair in "$FROM_PRIMARY:$TO_PRIMARY" "$FROM_SECONDARY:$TO_SECONDARY"; do
  from="$HOME/${pair%:*}"
  to="$HOME/${pair#*:}"
  [[ -d "$from" ]] || { echo "  $from missing — skipping"; continue; }
  if [[ -e "$to" ]]; then
    die "$to already exists — refusing to overwrite"
  fi
  run mv "$from" "$to"
done

# ── Phase 6: Patch eden config.json ─────────────────────────────────
log "Phase 6: Update $EDEN_CONFIG"
echo "+ python3 (rewrite path keys)"
if (( ! DRY_RUN )); then
  python3 <<PY
import json, sys
from pathlib import Path

cfg = Path("$EDEN_CONFIG")
data = json.loads(cfg.read_text())

renames = {
$(for i in "${!OLD_MOUNTS[@]}"; do
  printf '    "%s": "%s",\n' "${OLD_MOUNTS[$i]}" "${NEW_MOUNTS[$i]}"
done)
}

new_data = {}
for k, v in data.items():
    new_data[renames.get(k, k)] = v

cfg.write_text(json.dumps(new_data, indent=4, sort_keys=True) + "\n")
print(f"  rewrote {cfg} ({len(renames)} keys renamed)")
PY
fi

# ── Phase 7: Mount at new paths ─────────────────────────────────────
log "Phase 7: eden mount (at new paths)"
for new in "${NEW_MOUNTS[@]}"; do
  if [[ -L "$new/.eden/root" ]]; then
    echo "  $new already mounted — skipping"
  else
    run eden mount "$new" || warn "mount of $new failed"
  fi
done

# ── Phase 8: Fix bind redirections ──────────────────────────────────
# Bind redirection targets contain the mount path with /'s replaced by
# Z's. After the rename those targets are stale. 'eden redirect fixup'
# recreates them at the new encoded path.
log "Phase 8: eden redirect fixup"
for new in "${NEW_MOUNTS[@]}"; do
  run eden redirect fixup --mount "$new" || warn "redirect fixup failed for $new"
done

# ── Phase 9: Workspace symlinks ─────────────────────────────────────
log "Phase 9: Update ~/<name>.code-workspace symlinks"
for pair in "$FROM_PRIMARY:$TO_PRIMARY" "$FROM_SECONDARY:$TO_SECONDARY"; do
  from_name="${pair%:*}"
  to_name="${pair#*:}"
  old_link="$HOME/$from_name.code-workspace"
  new_link="$HOME/$to_name.code-workspace"
  new_target="$HOME/dotfiles/$to_name.code-workspace"

  if [[ -L "$old_link" ]]; then
    run rm "$old_link"
  elif [[ -e "$old_link" ]]; then
    warn "$old_link exists and is not a symlink; leaving alone"
  fi

  if [[ -L "$new_link" ]] && [[ "$(readlink "$new_link")" == "$new_target" ]]; then
    echo "  $new_link -> $new_target (already linked)"
  elif [[ -e "$new_link" ]]; then
    warn "$new_link exists but is not the expected symlink; leaving alone"
  elif [[ -e "$new_target" ]]; then
    run ln -s "$new_target" "$new_link"
  else
    warn "$new_target missing — skipping symlink (run dotsync first?)"
  fi
done

# ── Phase 10: Update .localrc ───────────────────────────────────────
# .localrc is per-machine (not dotsynced). Update its workspace name
# pattern matches in place. Backed up first.
log "Phase 10: Patch ~/.localrc"
LOCALRC="$HOME/.localrc"
if [[ -f "$LOCALRC" ]]; then
  cp -a "$LOCALRC" "$LOG_DIR/localrc.bak"
  if grep -qE "\"\\\$HOME\"/$FROM_PRIMARY\b|\"\\\$HOME/$FROM_PRIMARY\"|\"\\\$HOME\"/$FROM_SECONDARY\b" "$LOCALRC"; then
    run sed -i \
      -e "s|\"\$HOME\"/$FROM_PRIMARY\\b|\"\$HOME\"/$TO_PRIMARY|g" \
      -e "s|\"\$HOME/$FROM_PRIMARY\"|\"\$HOME/$TO_PRIMARY\"|g" \
      -e "s|\"\$HOME\"/$FROM_SECONDARY\\b|\"\$HOME\"/$TO_SECONDARY|g" \
      -e "s|\"\$HOME/$FROM_SECONDARY\"|\"\$HOME/$TO_SECONDARY\"|g" \
      "$LOCALRC"
    echo "  patched (backup at $LOG_DIR/localrc.bak)"
  else
    echo "  no matching workspace patterns — skipping"
  fi
else
  warn "$LOCALRC not found"
fi

# ── Phase 11: Watchman cleanup ──────────────────────────────────────
log "Phase 11: watchman watch-del-all"
if command -v watchman >/dev/null; then
  run watchman watch-del-all || warn "watchman watch-del-all failed"
fi

# ── Phase 12: Verify ────────────────────────────────────────────────
log "Phase 12: Verify"
echo "+ eden list"
(( ! DRY_RUN )) && eden list 2>&1 | sed 's/^/    /'
for ws in "$TO_PRIMARY" "$TO_SECONDARY"; do
  echo "+ ls $HOME/$ws"
  (( ! DRY_RUN )) && ls "$HOME/$ws" 2>&1 | sed 's/^/    /'
  link="$HOME/$ws.code-workspace"
  if [[ -L "$link" ]]; then
    echo "  $link -> $(readlink "$link")"
  else
    warn "$link is not a symlink"
  fi
done

log "Done"
echo
echo "Logs / backups: $LOG_DIR"
echo "  - plan.txt          : pairs of old -> new paths"
echo "  - config.json.bak   : pre-rename Eden config (rollback source)"
echo "  - redirects-pre.txt : redirections before fixup"
echo "  - localrc.bak       : pre-patch .localrc"
echo
echo "If anything looks wrong, restore Eden config with:"
echo "  cp $LOG_DIR/config.json.bak $EDEN_CONFIG"
echo "  # then 'eden mount' the original paths"
