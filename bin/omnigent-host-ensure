#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${OMNIGENT_URL:-}" ]]; then
  if command -v omnigent-server-url >/dev/null 2>&1; then
    OMNIGENT_URL="$(omnigent-server-url)"
  elif [[ -x "$HOME/dotfiles/bin/omnigent-server-url" ]]; then
    OMNIGENT_URL="$("$HOME/dotfiles/bin/omnigent-server-url")"
  else
    OMNIGENT_URL="http://127.0.0.1:${OMNIGENT_PORT:-6767}"
  fi
fi
OMNIGENT_BIN="${OMNIGENT_BIN:-$HOME/.local/bin/omnigent}"

state_dir="$HOME/.omnigent"
target_id="$(printf '%s' "$OMNIGENT_URL" | cksum | awk '{print $1}')"
session_name="omnigent-host-${target_id}"

mkdir -p "$state_dir"

if [[ ! -x "$OMNIGENT_BIN" ]]; then
  if command -v omnigent >/dev/null 2>&1; then
    OMNIGENT_BIN="$(command -v omnigent)"
  else
    echo "ERROR: pinned omnigent not found at $HOME/.local/bin/omnigent or on PATH" >&2
    exit 1
  fi
fi

desired_host_id="$(awk '$1 == "host_id:" { print $2; exit }' "$state_dir/config.yaml" 2>/dev/null || true)"

host_online() {
  local status
  status="$("$OMNIGENT_BIN" host status --server "$OMNIGENT_URL" --json 2>/dev/null || true)"
  python3 -c '
import json
import sys

target, desired = sys.argv[1:]
try:
    payload = json.load(sys.stdin)
except (TypeError, ValueError):
    raise SystemExit(1)

for daemon in payload.get("daemons", []):
    if daemon.get("target", "").rstrip("/") != target.rstrip("/"):
        continue
    if desired and daemon.get("host_id") != desired:
        continue
    if daemon.get("host_status") == "online" and daemon.get("process") == "online":
        raise SystemExit(0)
raise SystemExit(1)
' "$OMNIGENT_URL" "$desired_host_id" <<<"$status"
}

daemon_identity_mismatch() {
  [[ -n "$desired_host_id" ]] || return 1
  local status
  status="$("$OMNIGENT_BIN" host status --server "$OMNIGENT_URL" --json 2>/dev/null || true)"
  python3 -c '
import json
import sys

target, desired = sys.argv[1:]
try:
    payload = json.load(sys.stdin)
except (TypeError, ValueError):
    raise SystemExit(1)

for daemon in payload.get("daemons", []):
    if daemon.get("target", "").rstrip("/") == target.rstrip("/"):
        host_id = daemon.get("host_id")
        if host_id and host_id != desired:
            raise SystemExit(0)
raise SystemExit(1)
' "$OMNIGENT_URL" "$desired_host_id" <<<"$status"
}

"$OMNIGENT_BIN" config set --global "server=${OMNIGENT_URL}" >/dev/null

if host_online; then
  echo "[Omnigent] host already online for $OMNIGENT_URL"
  exit 0
fi

if ! curl -sf "${OMNIGENT_URL}/health" >/dev/null 2>&1; then
  echo "WARNING: Omnigent server is not reachable at ${OMNIGENT_URL}; host daemon may retry or exit" >&2
fi

if command -v tmux >/dev/null 2>&1; then
  tmux_bin="$(command -v tmux)"
elif [[ -x /opt/homebrew/bin/tmux ]]; then
  tmux_bin="/opt/homebrew/bin/tmux"
elif [[ -x /usr/local/bin/tmux ]]; then
  tmux_bin="/usr/local/bin/tmux"
else
  tmux_bin=""
fi

if [[ -n "$tmux_bin" ]]; then
  if "$tmux_bin" has-session -t "$session_name" 2>/dev/null && daemon_identity_mismatch; then
    echo "[Omnigent] replacing host daemon with mismatched identity"
    "$OMNIGENT_BIN" host stop --server "$OMNIGENT_URL" --daemon-only --force >/dev/null 2>&1 || true
    "$tmux_bin" kill-session -t "$session_name" 2>/dev/null || true
  fi
  if ! "$tmux_bin" has-session -t "$session_name" 2>/dev/null; then
    "$tmux_bin" new-session -d -s "$session_name" "exec '$OMNIGENT_BIN' host --server '$OMNIGENT_URL' --non-interactive"
  fi
  launcher="tmux session $session_name"
elif command -v screen >/dev/null 2>&1; then
  if ! screen -ls "$session_name" 2>/dev/null | grep -Fq ".$session_name"; then
    screen -dmS "$session_name" "$OMNIGENT_BIN" host --server "$OMNIGENT_URL" --non-interactive
  fi
  launcher="screen session $session_name"
else
  nohup "$OMNIGENT_BIN" host --server "$OMNIGENT_URL" --non-interactive >/dev/null 2>&1 &
  disown "$!" 2>/dev/null || true
  launcher="background process"
fi

for _ in $(seq 1 20); do
  if host_online; then
    echo "[Omnigent] host online for $OMNIGENT_URL via $launcher"
    exit 0
  fi
  sleep 0.5
done

echo "WARNING: Omnigent host did not report online for $OMNIGENT_URL after starting via $launcher" >&2
exit 1
