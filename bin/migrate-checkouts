#!/usr/bin/env bash
# Migrate fbsource + configerator Eden mounts from the legacy
#   ~/fbsource{,2,3}, ~/configerator{,2,3}, /data/users/$USER/fbsource*
# layout to a clean per-workspace structure:
#   ~/<PRIMARY_NAME>/{fbsource,configerator}
#   ~/<SECONDARY_NAME>/{fbsource,configerator}
#
# Run on each devserver. Idempotent for the clone phase. Conservative:
# refuses to destroy mounts with draft commits unless --force-destroy.
#
# Usage:
#   migrate-checkouts [--dry-run] [--force-destroy]
#                     [--primary NAME] [--secondary NAME]
#
# Env overrides: PRIMARY_NAME, SECONDARY_NAME

set -euo pipefail

PRIMARY_NAME="${PRIMARY_NAME:-main}"
SECONDARY_NAME="${SECONDARY_NAME:-scratch}"
DRY_RUN=0
FORCE_DESTROY=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)        DRY_RUN=1; shift ;;
    --force-destroy)  FORCE_DESTROY=1; shift ;;
    --primary)        PRIMARY_NAME="$2"; shift 2 ;;
    --secondary)      SECONDARY_NAME="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

LOG_DIR="$HOME/migrate-checkouts-$(date +%Y%m%d-%H%M%S)"
PRIMARY_DIR="$HOME/$PRIMARY_NAME"
SECONDARY_DIR="$HOME/$SECONDARY_NAME"

log()   { printf '\n=== %s ===\n' "$*"; }
warn()  { printf 'WARN: %s\n' "$*" >&2; }
die()   { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
run()   { if (( DRY_RUN )); then echo "+ $*"; else echo "+ $*"; "$@"; fi; }

confirm() {
  local prompt="$1" ans
  read -rp "$prompt [type 'yes' to proceed]: " ans
  [[ "$ans" == "yes" ]] || die "Aborted by user."
}

eden_mounts() {
  eden list 2>/dev/null | awk 'NR>1 {print $1}' | sort -u
}

is_inside_mount() {
  local path="$1" m
  for m in $(eden_mounts); do
    case "$path" in "$m"|"$m"/*) return 0 ;; esac
  done
  return 1
}

# ── Preflight ───────────────────────────────────────────────────────
mkdir -p "$LOG_DIR"
log "Migration log: $LOG_DIR"
echo "Hostname: $(hostname)"
echo "Mode: $((DRY_RUN)) dry-run, $((FORCE_DESTROY)) force-destroy"
echo "Primary:   $PRIMARY_DIR"
echo "Secondary: $SECONDARY_DIR"

cd "$HOME"
if is_inside_mount "$PWD"; then
  die "cwd $PWD is inside an Eden mount. Open a fresh shell in \$HOME and re-run."
fi

for cmd in eden fbclone sl; do
  command -v "$cmd" >/dev/null || die "$cmd not on PATH"
done

# ── Phase 1: Inventory ──────────────────────────────────────────────
log "Phase 1: Inventory existing Eden mounts"
mapfile -t MOUNTS < <(eden_mounts)
printf '%s\n' "${MOUNTS[@]}" | tee "$LOG_DIR/mounts.txt"

# Determine which mounts to remove. Anything whose basename starts with
# fbsource or configerator is in scope.
TO_REMOVE=()
for m in "${MOUNTS[@]}"; do
  base=$(basename "$m")
  case "$base" in
    fbsource*|configerator*) TO_REMOVE+=("$m") ;;
    *) warn "Skipping non-fbsource/configerator mount: $m" ;;
  esac
done

# Make sure the new destinations don't collide with mounts we're keeping.
for dest in "$PRIMARY_DIR/fbsource" "$PRIMARY_DIR/configerator" \
            "$SECONDARY_DIR/fbsource" "$SECONDARY_DIR/configerator"; do
  for m in "${MOUNTS[@]}"; do
    if [[ "$m" == "$dest" ]]; then
      warn "Destination $dest is already an Eden mount; will skip its clone."
    fi
  done
done

# ── Phase 2: Save redirections ──────────────────────────────────────
log "Phase 2: Save 'eden redirect' state"
REDIRECT_LOG="$LOG_DIR/redirects.txt"
: > "$REDIRECT_LOG"
for m in "${TO_REMOVE[@]}"; do
  printf '\n=== %s ===\n' "$m" >> "$REDIRECT_LOG"
  eden redirect list --mount "$m" >> "$REDIRECT_LOG" 2>&1 || true
done
echo "Redirections -> $REDIRECT_LOG"

# ── Phase 3: Draft check ────────────────────────────────────────────
log "Phase 3: Check for draft commits in mounts to be destroyed"
DRAFT_LOG="$LOG_DIR/drafts.txt"
: > "$DRAFT_LOG"
ANY_DRAFTS=0
for m in "${TO_REMOVE[@]}"; do
  drafts=$(sl --cwd "$m" log -r 'draft()' \
              -T '{node|short} {bookmarks} {desc|firstline}\n' 2>/dev/null || true)
  if [[ -n "$drafts" ]]; then
    ANY_DRAFTS=1
    {
      printf '\n=== %s ===\n' "$m"
      echo "$drafts"
    } >> "$DRAFT_LOG"
  fi
done

if (( ANY_DRAFTS )); then
  echo
  cat "$DRAFT_LOG"
  echo
  if (( ! FORCE_DESTROY )); then
    cat <<EOF >&2

Draft commits exist in one or more mounts above. They will be DESTROYED
by 'eden rm'. Push anything you care about first:

  sl push --cwd <mount> --to user/$USER/<bookmark> -r <rev>

Then re-run with --force-destroy.
EOF
    exit 1
  else
    warn "Proceeding with --force-destroy despite drafts."
  fi
else
  echo "No draft commits in any in-scope mount."
fi

# ── Phase 4: Confirm ────────────────────────────────────────────────
log "Phase 4: Confirm destruction plan"
echo "Will remove:"
printf '  eden rm %s\n' "${TO_REMOVE[@]}"
echo
echo "Will then clone:"
echo "  fbclone fbsource     $PRIMARY_DIR/fbsource"
echo "  fbclone configerator $PRIMARY_DIR/configerator"
echo "  fbclone fbsource     $SECONDARY_DIR/fbsource"
echo "  fbclone configerator $SECONDARY_DIR/configerator"
echo
if (( DRY_RUN )); then
  log "Dry run complete. No changes made."
  exit 0
fi
confirm "Proceed?"

# ── Phase 5: Destroy ────────────────────────────────────────────────
log "Phase 5: eden rm"
for m in "${TO_REMOVE[@]}"; do
  if ! run eden rm -y "$m"; then
    warn "eden rm failed for $m (continuing)"
  fi
done

# Drop dead ~/local symlinks if they're no longer pointing at live mounts.
for link in "$HOME/fbsource" "$HOME/configerator"; do
  if [[ -L "$link" ]]; then
    target=$(readlink -f "$link" 2>/dev/null || true)
    if [[ -z "$target" || ! -e "$target" ]]; then
      run rm -f "$link"
    fi
  fi
done
for d in "$HOME/local/fbsource" "$HOME/local/configerator"; do
  [[ -d "$d" ]] && [[ -z "$(ls -A "$d" 2>/dev/null)" ]] && run rmdir "$d" || true
done

# ── Phase 6: Reclone ────────────────────────────────────────────────
log "Phase 6: fbclone into the new layout"
run mkdir -p "$PRIMARY_DIR" "$SECONDARY_DIR"

clone_one() {
  local repo="$1" dest="$2"
  if [[ -e "$dest" ]]; then
    warn "$dest exists, skipping fbclone"
    return
  fi
  if ! run fbclone "$repo" "$dest"; then
    warn "fbclone $repo $dest failed"
  fi
}

clone_one fbsource     "$PRIMARY_DIR/fbsource"
clone_one configerator "$PRIMARY_DIR/configerator"
clone_one fbsource     "$SECONDARY_DIR/fbsource"
clone_one configerator "$SECONDARY_DIR/configerator"

# ── Phase 7: Cleanup ────────────────────────────────────────────────
log "Phase 7: Cleanup"
if command -v watchman >/dev/null; then
  run watchman watch-del-all || warn "watchman watch-del-all failed"
fi

log "Done"
cat <<EOF

Next steps:
  1. Review redirections at $REDIRECT_LOG. Re-apply any custom
     'eden redirect add' you want to preserve.
  2. If you had drafts, pull the wip bookmarks back into the new clones:
       sl pull -B user/$USER/<bookmark> --cwd $PRIMARY_DIR/fbsource
  3. Verify:
       ls $PRIMARY_DIR $SECONDARY_DIR
       eden list

EOF
