#!/usr/bin/env bash
# Migrate fbsource + configerator Eden mounts from the legacy
#   ~/fbsource{,2,3}, ~/configerator{,2,3}, /data/users/$USER/fbsource*
# layout to a clean per-workspace structure:
#   ~/<PRIMARY_NAME>/{fbsource,configerator}
#   ~/<SECONDARY_NAME>/{fbsource,configerator}
#
# Run on each devserver. Idempotent for the clone phase. Conservative:
# refuses to destroy mounts with draft commits unless --force-destroy.
#
# Usage:
#   migrate-checkouts [--dry-run] [--force-destroy]
#                     [--no-restore-drafts] [--no-restore-shelves]
#                     [--primary NAME] [--secondary NAME]
#
# Env overrides: PRIMARY_NAME, SECONDARY_NAME

set -euo pipefail

PRIMARY_NAME="${PRIMARY_NAME:-checkout1}"
SECONDARY_NAME="${SECONDARY_NAME:-checkout2}"
DRY_RUN=0
FORCE_DESTROY=0
RESTORE_DRAFTS=1
RESTORE_SHELVES=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)            DRY_RUN=1; shift ;;
    --force-destroy)      FORCE_DESTROY=1; shift ;;
    --no-restore-drafts)  RESTORE_DRAFTS=0; shift ;;
    --no-restore-shelves) RESTORE_SHELVES=0; shift ;;
    --primary)            PRIMARY_NAME="$2"; shift 2 ;;
    --secondary)          SECONDARY_NAME="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

LOG_DIR="$HOME/migrate-checkouts-$(date +%Y%m%d-%H%M%S)"
PRIMARY_DIR="$HOME/$PRIMARY_NAME"
SECONDARY_DIR="$HOME/$SECONDARY_NAME"

log()   { printf '\n=== %s ===\n' "$*"; }
warn()  { printf 'WARN: %s\n' "$*" >&2; }
die()   { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
run()   { if (( DRY_RUN )); then echo "+ $*"; else echo "+ $*"; "$@"; fi; }

confirm() {
  local prompt="$1" ans
  read -rp "$prompt [type 'yes' to proceed]: " ans
  [[ "$ans" == "yes" ]] || die "Aborted by user."
}

eden_mounts() {
  eden list 2>/dev/null | awk 'NR>1 {print $1}' | sort -u
}

is_inside_mount() {
  local path="$1" m
  for m in $(eden_mounts); do
    case "$path" in "$m"|"$m"/*) return 0 ;; esac
  done
  return 1
}

# ── Preflight ───────────────────────────────────────────────────────
mkdir -p "$LOG_DIR"
log "Migration log: $LOG_DIR"
echo "Hostname: $(hostname)"
echo "Mode: $((DRY_RUN)) dry-run, $((FORCE_DESTROY)) force-destroy"
echo "Primary:   $PRIMARY_DIR"
echo "Secondary: $SECONDARY_DIR"

cd "$HOME"
if is_inside_mount "$PWD"; then
  die "cwd $PWD is inside an Eden mount. Open a fresh shell in \$HOME and re-run."
fi

for cmd in eden fbclone sl; do
  command -v "$cmd" >/dev/null || die "$cmd not on PATH"
done

# ── Phase 1: Inventory ──────────────────────────────────────────────
log "Phase 1: Inventory existing Eden mounts"
mapfile -t MOUNTS < <(eden_mounts)
printf '%s\n' "${MOUNTS[@]}" | tee "$LOG_DIR/mounts.txt"

# Determine which mounts to remove. Anything whose basename starts with
# fbsource or configerator is in scope.
TO_REMOVE=()
for m in "${MOUNTS[@]}"; do
  base=$(basename "$m")
  case "$base" in
    fbsource*|configerator*) TO_REMOVE+=("$m") ;;
    *) warn "Skipping non-fbsource/configerator mount: $m" ;;
  esac
done

# Make sure the new destinations don't collide with mounts we're keeping.
for dest in "$PRIMARY_DIR/fbsource" "$PRIMARY_DIR/configerator" \
            "$SECONDARY_DIR/fbsource" "$SECONDARY_DIR/configerator"; do
  for m in "${MOUNTS[@]}"; do
    if [[ "$m" == "$dest" ]]; then
      warn "Destination $dest is already an Eden mount; will skip its clone."
    fi
  done
done

# ── Phase 2: Save redirections ──────────────────────────────────────
log "Phase 2: Save 'eden redirect' state"
REDIRECT_LOG="$LOG_DIR/redirects.txt"
: > "$REDIRECT_LOG"
for m in "${TO_REMOVE[@]}"; do
  printf '\n=== %s ===\n' "$m" >> "$REDIRECT_LOG"
  eden redirect list --mount "$m" >> "$REDIRECT_LOG" 2>&1 || true
done
echo "Redirections -> $REDIRECT_LOG"

# ── Phase 3a: Auto-backup shelves ───────────────────────────────────
# Shelves live in the Eden client state dir at <state_dir>/sl-repo-dir/
# {shelved,shelve-backup}/. They're local-only — Commit Cloud does NOT
# sync them. Copy them out before destruction so they survive.
log "Phase 3a: Auto-backup shelves to $LOG_DIR/shelves/"
SHELVE_LOG="$LOG_DIR/shelves.txt"
: > "$SHELVE_LOG"
for m in "${TO_REMOVE[@]}"; do
  client=$(readlink "$m/.eden/client" 2>/dev/null || true)
  [[ -z "$client" ]] && { warn "No .eden/client for $m, skipping shelve backup"; continue; }
  src_shelved="$client/sl-repo-dir/shelved"
  src_backup="$client/sl-repo-dir/shelve-backup"
  basename=$(basename "$client")
  dest="$LOG_DIR/shelves/$basename"
  for src in "$src_shelved" "$src_backup"; do
    [[ -d "$src" ]] || continue
    [[ -z "$(ls -A "$src" 2>/dev/null)" ]] && continue
    sub=$(basename "$src")
    run mkdir -p "$dest/$sub"
    if (( ! DRY_RUN )); then
      cp -a "$src/." "$dest/$sub/" || warn "Failed to copy $src"
    fi
    echo "  $m -> $dest/$sub" | tee -a "$SHELVE_LOG"
    ls -1 "$src" 2>/dev/null | sed 's/^/    /' | tee -a "$SHELVE_LOG"
  done
done
[[ -s "$SHELVE_LOG" ]] || echo "  (no shelves found)"

# ── Phase 3b: Flush Commit Cloud ────────────────────────────────────
# Push any not-yet-uploaded drafts before we check for unbacked drafts.
log "Phase 3b: Flush Commit Cloud (sl cloud sync)"
for m in "${TO_REMOVE[@]}"; do
  echo "+ sl cloud sync --cwd $m"
  if (( ! DRY_RUN )); then
    sl --cwd "$m" cloud sync 2>&1 | sed 's/^/    /' || warn "cloud sync failed for $m"
  fi
done

# ── Phase 3c: Loss check ────────────────────────────────────────────
# What 'eden rm' actually destroys that we can't recover:
#   1. Uncommitted working-copy edits ('sl status'). Not in any backup.
#   2. Draft commits NOT yet uploaded to Commit Cloud (post-flush).
# Shelves are handled by Phase 3a above. Cloud-synced drafts come back
# via 'sl cloud sync' in the new clones.
log "Phase 3c: Check for state that would still be lost"
LOSS_LOG="$LOG_DIR/at-risk.txt"
: > "$LOSS_LOG"
ANY_LOSS=0

note_loss() {
  ANY_LOSS=1
  printf '%s\n' "$*" >> "$LOSS_LOG"
}

for m in "${TO_REMOVE[@]}"; do
  printf '\n=== %s ===\n' "$m" >> "$LOSS_LOG"

  pending=$(sl --cwd "$m" status 2>/dev/null || true)
  if [[ -n "$pending" ]]; then
    note_loss "Uncommitted changes (NOT recoverable):"
    note_loss "$pending"
  fi

  unbacked=$(sl --cwd "$m" cloud check -r 'draft()' 2>/dev/null \
             | awk '/not backed up/ {print $1}' || true)
  if [[ -n "$unbacked" ]]; then
    note_loss "Draft commits NOT in Commit Cloud (post-flush):"
    while IFS= read -r h; do
      [[ -z "$h" ]] && continue
      summary=$(sl --cwd "$m" log -r "$h" \
                  -T '{node|short} {date|isodate} {desc|firstline}\n' 2>/dev/null || echo "$h")
      note_loss "  $summary"
    done <<< "$unbacked"
  fi
done

CLOUD_AUTO=$(sl --cwd "${TO_REMOVE[0]:-$HOME}" cloud status 2>/dev/null \
             | awk -F': *' '/Automatic Sync \(on local changes\)/ {print $2}')
if [[ "$CLOUD_AUTO" != "ON" ]]; then
  note_loss ""
  note_loss "WARNING: Commit Cloud automatic sync is '$CLOUD_AUTO' (expected 'ON')."
  note_loss "All draft commits across all mounts may be at risk."
fi

if (( ANY_LOSS )); then
  echo
  cat "$LOSS_LOG"
  echo
  if (( ! FORCE_DESTROY )); then
    cat <<EOF >&2

The state above is NOT recoverable after 'eden rm'. Options:

  - Commit + cloud-sync uncommitted edits:
      sl commit --cwd <mount> -m '...'   # then 'sl cloud sync'
  - For unbacked drafts, push to a personal bookmark:
      sl push --cwd <mount> --to user/$USER/<name> -r <hash>
  - If you don't care, re-run with --force-destroy.

Shelves are already auto-backed up to $LOG_DIR/shelves/.
Cloud-synced drafts are recoverable via 'sl cloud sync' in new clones.
EOF
    exit 1
  else
    warn "Proceeding with --force-destroy despite at-risk state above."
  fi
else
  echo "No at-risk state. Shelves backed up; cloud-synced drafts recoverable."
fi

# ── Phase 4: Confirm ────────────────────────────────────────────────
log "Phase 4: Confirm destruction plan"
echo "Will remove:"
printf '  eden rm %s\n' "${TO_REMOVE[@]}"
echo
echo "Will then clone:"
echo "  fbclone fbsource     $PRIMARY_DIR/fbsource"
echo "  fbclone configerator $PRIMARY_DIR/configerator"
echo "  fbclone fbsource     $SECONDARY_DIR/fbsource"
echo "  fbclone configerator $SECONDARY_DIR/configerator"
echo
if (( DRY_RUN )); then
  log "Dry run complete. No changes made."
  exit 0
fi
confirm "Proceed?"

# ── Phase 4b: Free busy mounts ──────────────────────────────────────
# Anything with cwd or open files inside an in-scope mount will block
# 'eden rm'. Auto-kill the user's own nvs-managed nvim servers (and
# their watchdogs); list anything else for manual handling.
log "Phase 4b: Free busy mounts"

# Kill watchdogs first so they don't respawn the nvim servers we're
# about to kill.
killed_any=0
mapfile -t watchdog_pids < <(pgrep -u "$USER" -f 'nvs --server-only' 2>/dev/null || true)
for pid in "${watchdog_pids[@]}"; do
  [[ -z "$pid" ]] && continue
  echo "  killing nvs watchdog pid $pid"
  if (( ! DRY_RUN )); then kill "$pid" 2>/dev/null && killed_any=1; fi
done

# Then kill any headless nvim whose cwd is inside an in-scope mount.
mapfile -t headless_pids < <(pgrep -u "$USER" -f 'nvim --headless --listen' 2>/dev/null || true)
for pid in "${headless_pids[@]}"; do
  cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null || true)
  for m in "${TO_REMOVE[@]}"; do
    case "$cwd" in
      "$m"|"$m"/*)
        echo "  killing nvim pid $pid (cwd $cwd)"
        if (( ! DRY_RUN )); then kill "$pid" 2>/dev/null && killed_any=1; fi
        break
        ;;
    esac
  done
done

(( killed_any )) && sleep 1   # let processes actually exit

# Now look for anything else holding files in the mounts.
busy_log="$LOG_DIR/busy-mounts.txt"
: > "$busy_log"
any_busy=0
for m in "${TO_REMOVE[@]}"; do
  busy=""
  for pid_dir in /proc/[0-9]*; do
    pid=$(basename "$pid_dir")
    cwd=$(readlink "$pid_dir/cwd" 2>/dev/null || true)
    case "$cwd" in
      "$m"|"$m"/*)
        comm=$(cat "$pid_dir/comm" 2>/dev/null || echo "?")
        busy+="    $pid  $comm  (cwd: $cwd)"$'\n'
        ;;
    esac
  done
  if [[ -n "$busy" ]]; then
    any_busy=1
    {
      printf '\n=== %s ===\n' "$m"
      printf '%s' "$busy"
    } >> "$busy_log"
  fi
done

if (( any_busy )); then
  echo
  cat "$busy_log"
  echo
  if (( ! FORCE_DESTROY )); then
    cat <<EOF >&2
Processes above have cwd inside in-scope mounts. They will block
'eden rm'. Kill them and re-run, or use --force-destroy.
EOF
    exit 1
  else
    warn "Proceeding with --force-destroy despite busy mounts."
  fi
else
  echo "  No remaining processes hold files in in-scope mounts."
fi

# ── Phase 5: Destroy ────────────────────────────────────────────────
log "Phase 5: eden rm"
for m in "${TO_REMOVE[@]}"; do
  if ! run eden rm -y "$m"; then
    warn "eden rm failed for $m (continuing)"
  fi
done

# Drop dead ~/local symlinks if they're no longer pointing at live mounts.
for link in "$HOME/fbsource" "$HOME/configerator"; do
  if [[ -L "$link" ]]; then
    target=$(readlink -f "$link" 2>/dev/null || true)
    if [[ -z "$target" || ! -e "$target" ]]; then
      run rm -f "$link"
    fi
  fi
done
for d in "$HOME/local/fbsource" "$HOME/local/configerator"; do
  [[ -d "$d" ]] && [[ -z "$(ls -A "$d" 2>/dev/null)" ]] && run rmdir "$d" || true
done

# ── Phase 6: Reclone ────────────────────────────────────────────────
log "Phase 6: fbclone into the new layout"
run mkdir -p "$PRIMARY_DIR" "$SECONDARY_DIR"

clone_one() {
  local repo="$1" dest="$2"
  if [[ -e "$dest" ]]; then
    warn "$dest exists, skipping fbclone"
    return
  fi
  if ! run fbclone "$repo" "$dest"; then
    warn "fbclone $repo $dest failed"
  fi
}

clone_one fbsource     "$PRIMARY_DIR/fbsource"
clone_one configerator "$PRIMARY_DIR/configerator"
clone_one fbsource     "$SECONDARY_DIR/fbsource"
clone_one configerator "$SECONDARY_DIR/configerator"

# ── Phase 7: Workspace symlinks ─────────────────────────────────────
# Symlink ~/<name>.code-workspace -> ~/dotfiles/<name>.code-workspace
# so VS Code remote-SSH (referenced from the Mac startup-windows script)
# can open them. Idempotent.
log "Phase 7: VS Code workspace symlinks"
for name in "$PRIMARY_NAME" "$SECONDARY_NAME"; do
  src="$HOME/dotfiles/$name.code-workspace"
  dest="$HOME/$name.code-workspace"
  if [[ ! -e "$src" ]]; then
    warn "$src missing — skipping symlink for $name (create it in dotfiles first)"
    continue
  fi
  if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
    echo "  $dest -> $src (already linked)"
    continue
  fi
  if [[ -e "$dest" ]]; then
    warn "$dest exists and is not the expected symlink; leaving alone"
    continue
  fi
  run ln -s "$src" "$dest"
done

# ── Phase 8: Restore drafts from Commit Cloud ───────────────────────
NEW_CLONES=(
  "$PRIMARY_DIR/fbsource"
  "$PRIMARY_DIR/configerator"
  "$SECONDARY_DIR/fbsource"
  "$SECONDARY_DIR/configerator"
)
if (( RESTORE_DRAFTS )); then
  log "Phase 8: Restore drafts (sl cloud sync) in each new clone"
  for d in "${NEW_CLONES[@]}"; do
    [[ -d "$d/.eden" ]] || { warn "$d not an Eden mount, skipping cloud sync"; continue; }
    echo "+ sl cloud sync --cwd $d"
    if (( ! DRY_RUN )); then
      sl --cwd "$d" cloud sync 2>&1 | sed 's/^/    /' || warn "cloud sync failed for $d"
    fi
  done
else
  log "Phase 8: Skipping draft restore (--no-restore-drafts)"
fi

# ── Phase 9: Restore shelves ────────────────────────────────────────
# Map each old Eden client's shelves into the appropriate new clone.
# Heuristic: bare client name (e.g. "fbsource", "configerator") -> primary
# workspace; any suffixed client (e.g. "fbsource2", "fbsource2-1",
# "configerator3") -> secondary workspace. Same kind (fbsource/configerator)
# stays paired with the same kind.
restore_shelves_for_client() {
  local old="$1"  # e.g. "fbsource", "fbsource2-1", "configerator2"
  local kind ws_dir
  case "$old" in
    fbsource)      kind=fbsource;     ws_dir="$PRIMARY_DIR" ;;
    fbsource*)     kind=fbsource;     ws_dir="$SECONDARY_DIR" ;;
    configerator)  kind=configerator; ws_dir="$PRIMARY_DIR" ;;
    configerator*) kind=configerator; ws_dir="$SECONDARY_DIR" ;;
    *) warn "Unknown old client kind: $old"; return ;;
  esac
  local new_clone="$ws_dir/$kind"
  [[ -d "$new_clone/.eden" ]] || { warn "$new_clone not an Eden mount, skipping shelve restore"; return; }
  local new_state; new_state=$(readlink "$new_clone/.eden/client" 2>/dev/null)
  [[ -n "$new_state" ]] || { warn "Cannot resolve client dir for $new_clone"; return; }

  for sub in shelved shelve-backup; do
    local src="$LOG_DIR/shelves/$old/$sub"
    [[ -d "$src" ]] || continue
    [[ -z "$(ls -A "$src" 2>/dev/null)" ]] && continue
    local dest="$new_state/sl-repo-dir/$sub"
    run mkdir -p "$dest"
    if (( ! DRY_RUN )); then
      # -n = no-clobber. Warn on collisions so user can resolve manually.
      local collisions
      collisions=$(comm -12 \
        <(ls -1 "$src"  2>/dev/null | sort) \
        <(ls -1 "$dest" 2>/dev/null | sort))
      if [[ -n "$collisions" ]]; then
        warn "Shelve name collision(s) in $dest (kept existing):"
        echo "$collisions" | sed 's/^/    /' >&2
      fi
      cp -an "$src/." "$dest/" || warn "cp failed for $src -> $dest"
    fi
    echo "  $old/$sub -> $new_clone ($dest)"
  done
}

if (( RESTORE_SHELVES )); then
  log "Phase 9: Restore shelves into new clones"
  if [[ -d "$LOG_DIR/shelves" ]]; then
    for old_dir in "$LOG_DIR/shelves"/*; do
      [[ -d "$old_dir" ]] || continue
      restore_shelves_for_client "$(basename "$old_dir")"
    done
  else
    echo "  (no shelves were backed up)"
  fi
else
  log "Phase 9: Skipping shelve restore (--no-restore-shelves)"
fi

# ── Phase 10: Verify ────────────────────────────────────────────────
log "Phase 10: Verify"
echo "+ eden list"
if (( ! DRY_RUN )); then eden list 2>&1 | sed 's/^/    /'; fi
for d in "$PRIMARY_DIR" "$SECONDARY_DIR"; do
  echo "+ ls $d"
  if (( ! DRY_RUN )); then ls "$d" 2>&1 | sed 's/^/    /'; fi
done
for ws in "$PRIMARY_NAME" "$SECONDARY_NAME"; do
  link="$HOME/$ws.code-workspace"
  if [[ -L "$link" ]]; then
    echo "  $link -> $(readlink "$link")"
  else
    warn "$link is not a symlink"
  fi
done

# ── Phase 11: Cleanup ───────────────────────────────────────────────
log "Phase 11: Cleanup"
if command -v watchman >/dev/null; then
  run watchman watch-del-all || warn "watchman watch-del-all failed"
fi

log "Done"
echo
echo "Logs / backups: $LOG_DIR"
echo "  - mounts.txt    : pre-migration Eden mount list"
echo "  - redirects.txt : pre-migration eden redirect state (re-apply manually if any)"
echo "  - shelves/      : raw shelve files copied out of old mounts"
echo "  - at-risk.txt   : items that would have been lost (if any)"
echo
