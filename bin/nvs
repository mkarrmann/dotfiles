#!/usr/bin/env bash
set -euo pipefail

name="${1:?usage: nvs SESSION_NAME [WORKDIR]}"
workdir="${2:-}"

base="${XDG_STATE_HOME:-$HOME/.local/state}/nvim-sessions"
log="$base/$name.log"

mkdir -p "$base"

# Deterministic port from session name (range 7100-7899)
port=$(($(echo -n "$name" | cksum | cut -d' ' -f1) % 800 + 7100))

is_live() {
  nvim --server "localhost:$port" --remote-expr '1' >/dev/null 2>&1
}

start() {
  local cmd=(nvim --headless --listen "localhost:$port")
  if [[ -n "$workdir" ]]; then
    local expanded="${workdir/#\~/$HOME}"
    cmd+=(--cmd "cd $expanded")
  fi
  nohup "${cmd[@]}" >>"$log" 2>&1 </dev/null &
  for _ in $(seq 1 50); do
    if is_live; then return 0; fi
    sleep 0.1
  done
  echo "Failed to start session: $name" >&2
  exit 1
}

if ! is_live; then
  start
fi

echo "$port"
