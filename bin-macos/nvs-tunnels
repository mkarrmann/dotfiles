#!/usr/bin/env bash
set -euo pipefail

# Establish ET tunnels for nvim remote sessions on a single devvm.
# Runs in a dedicated Ghostty window (workspace 1).
#
# Usage: nvs-tunnels HOST SESSION[:WORKDIR] [SESSION[:WORKDIR] ...]
# Example: nvs-tunnels devvm36111.ftw0.facebook.com FTW-main1 FTW-fbsource1:~/fbsource

host="${1:?usage: nvs-tunnels HOST SESSION[:WORKDIR] ...}"
shift

if [[ $# -eq 0 ]]; then
  echo "ERROR: at least one SESSION required" >&2
  exit 1
fi

nvs_port() {
  printf '%s' "$1" | cksum | awk '{ print 7000 + ($1 % 1000) }'
}

# Derive tunnel label from first session's prefix (e.g. "FTW" from "FTW-main1")
first_session="${1%%:*}"
prefix="${first_session%%-*}"
tunnel_label="${prefix}: tunnels"

tunnel_spec=""
remote_parts=()

for spec in "$@"; do
  session="${spec%%:*}"
  workdir="${spec#*:}"
  [[ "$workdir" == "$spec" ]] && workdir=""

  port=$(nvs_port "$session")
  if [[ -n "$tunnel_spec" ]]; then
    tunnel_spec+=","
  fi
  tunnel_spec+="${port}:${port}"
  remote_parts+=("nvs --server-only ${session}${workdir:+ ${workdir}}")

  echo "  $session -> localhost:$port"
done

remote_cmd=""
for part in "${remote_parts[@]}"; do
  remote_cmd+="${part} & "
done
remote_cmd+="wait"

echo ""
echo "Connecting to $host (Duo auth may be required)..."
echo ""

# Run ET in foreground (for Duo auth), but don't exec — keep our shell alive
# so we can maintain the window title for AeroSpace detection.
x2ssh -et "$host" \
  -t "$tunnel_spec" \
  -c "zsh -lc '${remote_cmd}'" &
et_pid=$!

# Periodically reset the window title so AeroSpace can identify this window,
# even if ET/remote shell overrides it.
while kill -0 "$et_pid" 2>/dev/null; do
  printf '\033]0;%s\007' "$tunnel_label"
  sleep 10
done

wait "$et_pid" 2>/dev/null || true
