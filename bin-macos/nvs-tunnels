#!/usr/bin/env bash
set -euo pipefail

# Establish ET tunnels for nvim remote sessions on a single devvm.
# Runs in a dedicated Ghostty window (workspace T).
#
# Sets up:
#   - Forward tunnels (-t) for each nvim session's RPC port
#   - Reverse tunnel (-r) for clipboard relay (devvm → Mac pbcopy)
#   - Remote headless nvim servers via nvs --server-only
#   - Local clipboard listener (nvs-clip-listen) for receiving yanked text
#
# Auto-reconnects if the ET session terminates (devvm restart, network
# outage beyond ET's tolerance, Duo expiry). Duo re-auth may be required.
#
# Usage: nvs-tunnels HOST SESSION[:WORKDIR] [SESSION[:WORKDIR] ...]
# Example: nvs-tunnels devvm36111.ftw0.facebook.com FTW-main1 FTW-main:~/main

NVS_CLIP_PORT="${NVS_CLIP_PORT:-8765}"
PERSISTENCE_PORT="${PERSISTENCE_PORT:-7847}"

host="${1:?usage: nvs-tunnels HOST SESSION[:WORKDIR] ...}"
shift

if [[ $# -eq 0 ]]; then
  echo "ERROR: at least one SESSION required" >&2
  exit 1
fi

nvs_port() {
  printf '%s' "$1" | cksum | awk '{ print 7000 + ($1 % 1000) }'
}

# Derive tunnel label from first session's prefix (e.g. "FTW" from "FTW-main1")
first_session="${1%%:*}"
prefix="${first_session%%-*}"
tunnel_label="${prefix}: tunnels"

tunnel_spec=""
remote_parts=()

for spec in "$@"; do
  session="${spec%%:*}"
  workdir="${spec#*:}"
  [[ "$workdir" == "$spec" ]] && workdir=""

  port=$(nvs_port "$session")
  if [[ -n "$tunnel_spec" ]]; then
    tunnel_spec+=","
  fi
  tunnel_spec+="${port}:${port}"
  remote_parts+=("nvs --server-only ${session}${workdir:+ ${workdir}}")

  echo "  $session -> localhost:$port"
done

# IMPORTANT: do NOT add single quotes anywhere inside remote_cmd. The
# whole string is embedded as `-c "zsh -lc '${remote_cmd}'"` below;
# any inner ' breaks the outer quoting and the remote shell silently
# parses only the prefix, producing a crash-loop with no nvs watchdogs.
#
# The acp-broker is owned by systemd --user on the devvm
# (~/dotfiles/systemd/acp-broker.service) — not kicked from here.
remote_cmd=""
for part in "${remote_parts[@]}"; do
  remote_cmd+="${part} & "
done
remote_cmd+="wait"

# Start clipboard listener if not already running
nvs-clip-listen &
disown

# Reconnect loop — ET handles transient network issues, but if the session
# itself terminates (devvm restart, Duo expiry, prolonged outage), we retry.
# Duo re-auth is interactive, so the user sees the prompt in this window.
while true; do
  echo ""
  echo "Connecting to $host (Duo auth may be required)..."
  echo ""

  # ET requires reverse tunnels to be merged into a single -r flag
  # (comma-separated), not passed as multiple -r flags. Same shape as
  # the -t forward-tunnel spec built above.
  x2ssh -et "$host" \
    -t "$tunnel_spec" \
    -r "$NVS_CLIP_PORT:$NVS_CLIP_PORT,$PERSISTENCE_PORT:$PERSISTENCE_PORT" \
    -c "zsh -lc '${remote_cmd}'" &
  et_pid=$!

  # Periodically reset the window title so AeroSpace can identify this window,
  # even if ET/remote shell overrides it.
  while kill -0 "$et_pid" 2>/dev/null; do
    printf '\033]0;%s\007' "$tunnel_label"
    sleep 10
  done

  wait "$et_pid" 2>/dev/null || true

  echo ""
  echo "ET session terminated. Reconnecting in 5s..."
  sleep 5
done
