#!/usr/bin/env bash
set -euo pipefail

host="${1:?usage: nvs HOST SESSION_NAME [WORKDIR]}"
name="${2:?usage: nvs HOST SESSION_NAME [WORKDIR]}"
workdir="${3:-}"

# Deterministic port from session name (must match remote nvs)
port=$(($(echo -n "$name" | cksum | cut -d' ' -f1) % 800 + 7100))

cleanup() {
  if [[ -n "${tunnel_pid:-}" ]]; then
    kill "$tunnel_pid" 2>/dev/null || true
    wait "$tunnel_pid" 2>/dev/null || true
  fi
}
trap cleanup EXIT

# Ensure remote headless server is running (also caches auth for ET)
x2ssh "$host" -c "nvs '$name' '$workdir'" >/dev/null

# Start ET tunnel with TCP port forwarding in background
x2ssh -et "$host" -t "$port:$port" -c 'exec cat' </dev/null &
tunnel_pid=$!

# Wait for tunnel to be ready
for _ in $(seq 1 40); do
  nvim --server "localhost:$port" --remote-expr '1' >/dev/null 2>&1 && break
  sleep 0.25
done

if ! nvim --server "localhost:$port" --remote-expr '1' >/dev/null 2>&1; then
  echo "Failed to establish ET tunnel to $host:$port" >&2
  exit 1
fi

# Attach local Neovim as remote UI
nvim --server "localhost:$port" --remote-ui
