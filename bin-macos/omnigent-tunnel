#!/usr/bin/env bash
# Serve stable Mac localhost:6767 through the existing CCO/FTW ET forwards.
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
PYTHON="$DOTFILES/services/omnigent-hub/.venv/bin/python"
SERVER_URL_BIN="${OMNIGENT_SERVER_URL_BIN:-$HOME/bin/omnigent-server-url}"

if [[ ! -x "$PYTHON" ]]; then
  echo "ERROR: omnigent-hub is not installed; run $DOTFILES/init.sh" >&2
  exit 1
fi

export OMNIGENT_PORT="${OMNIGENT_PORT:-$("$SERVER_URL_BIN" --port)}"
export OMNIGENT_PRIMARY_TUNNEL_PORT="${OMNIGENT_PRIMARY_TUNNEL_PORT:-$("$SERVER_URL_BIN" --primary-tunnel-port)}"
export OMNIGENT_STANDBY_TUNNEL_PORT="${OMNIGENT_STANDBY_TUNNEL_PORT:-$("$SERVER_URL_BIN" --standby-tunnel-port)}"

printf '\033]0;%s\007' "Omnigent: tunnel"
exec "$PYTHON" -m omnigent_hub.mac_proxy
