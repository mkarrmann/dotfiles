#!/usr/bin/env bash
# Called by AeroSpace on-window-detected to auto-move new windows into
# the accordion container on workspaces that have an Orchest sidebar.
#
# Tries `move left/right` to enter an existing accordion container.
# Falls back to arrange-workspaces when no container exists yet (the
# initial single-window case where join-with can't create one). Once
# the container is built, it persists (flatten-containers = false), so
# the fallback only fires once per workspace.

sleep 0.3

wid="${AEROSPACE_WINDOW_ID}"
[[ -z "$wid" ]] && exit 0

# Get window info
info=$(aerospace list-windows --all --format '%{window-id}|%{workspace}|%{window-title}' 2>/dev/null \
  | grep "^${wid}|")
[[ -z "$info" ]] && exit 0

ws=$(echo "$info" | cut -d'|' -f2)
title=$(echo "$info" | cut -d'|' -f3-)

# Don't move Orchest sidebar windows
[[ "$title" == *"Orchest ["* ]] && exit 0

# Only act on managed workspaces 1-9
case "$ws" in [1-9]) ;; *) exit 0 ;; esac

# Only act if this workspace has an Orchest sidebar (i.e. the layout is set up)
has_orchest=$(aerospace list-windows --workspace "$ws" --format '%{window-title}' 2>/dev/null \
  | grep -c 'Orchest \[')
[[ "$has_orchest" -eq 0 ]] && exit 0

# Don't act during startup-windows
[[ -f /tmp/startup-windows.lock ]] && exit 0

# Move the new window into the accordion container. It may appear on either
# side of the container depending on which window had focus when it was
# created. Try move left first; if still at root level, try move right.
aerospace focus --window-id "$wid" 2>/dev/null
aerospace move left 2>/dev/null

new_parent=$(aerospace list-windows --focused \
  --format '%{window-parent-container-layout}' 2>/dev/null)
new_root=$(aerospace list-windows --focused \
  --format '%{workspace-root-container-layout}' 2>/dev/null)
if [[ "$new_parent" == "$new_root" ]]; then
  aerospace move right 2>/dev/null

  new_parent=$(aerospace list-windows --focused \
    --format '%{window-parent-container-layout}' 2>/dev/null)
  new_root=$(aerospace list-windows --focused \
    --format '%{workspace-root-container-layout}' 2>/dev/null)
  if [[ "$new_parent" == "$new_root" ]]; then
    # No accordion container exists yet (workspace had sidebar + single
    # window). Now that there are 2+ non-Orchest windows, build the
    # container. Once created, it persists (flatten-containers = false).
    arrange-workspaces --force "$ws" >/dev/null 2>&1
  fi
fi
