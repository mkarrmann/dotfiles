#!/usr/bin/env bash
# Called by AeroSpace on-window-detected to integrate new windows into the
# sidebar+accordion layout on workspaces that have an Orchest sidebar.
#
# Always does a full `arrange-workspaces --force` rebuild. Earlier versions
# tried `aerospace move right` to slot the new window into the existing
# accordion container, but `move right` at a root-level boundary creates a
# perpendicular nested container (gotcha documented in arrange-workspaces),
# which corrupts the layout in ways subsequent runs don't fully repair.
# The full rebuild path was already the documented fallback — making it
# the only path is both simpler and correct.

# Don't act during startup-windows. Check FIRST — before sleep and before
# any aerospace calls. startup-windows creates ~30 windows in quick
# succession, spawning ~30 concurrent auto-accordion processes. If each
# makes list-windows calls before bailing, the AeroSpace CLI server
# saturates and `list-windows --all --json` can block indefinitely,
# deadlocking startup-windows itself.
[[ -f /tmp/startup-windows.lock ]] && exit 0

sleep 0.3

# Re-check: startup-windows may have grabbed the lock during our sleep.
[[ -f /tmp/startup-windows.lock ]] && exit 0

wid="${AEROSPACE_WINDOW_ID}"
[[ -z "$wid" ]] && exit 0

info=$(aerospace list-windows --all --format '%{window-id}|%{workspace}|%{window-title}' 2>/dev/null \
  | grep "^${wid}|")
[[ -z "$info" ]] && exit 0

ws=$(echo "$info" | cut -d'|' -f2)
title=$(echo "$info" | cut -d'|' -f3-)

# Don't move Orchest sidebar windows
[[ "$title" == *"Orchest ["* ]] && exit 0

# Only act on managed workspaces 1-9
case "$ws" in [1-9]) ;; *) exit 0 ;; esac

# Only act if this workspace has an Orchest sidebar (i.e. the layout is set up)
has_orchest=$(aerospace list-windows --workspace "$ws" --format '%{window-title}' 2>/dev/null \
  | grep -c 'Orchest \[')
[[ "$has_orchest" -eq 0 ]] && exit 0

arrange-workspaces --force "$ws" >/dev/null 2>&1
