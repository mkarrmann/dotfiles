#!/usr/bin/env bash
set -euo pipefail

# ── Args ─────────────────────────────────────────────────────────────
ORCHEST_MODE_FLAG=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --orchest-prod) ORCHEST_MODE_FLAG="--prod"; shift ;;
    --orchest-dev)  ORCHEST_MODE_FLAG="--dev";  shift ;;
    -h|--help)
      echo "Usage: startup-windows [--orchest-dev|--orchest-prod]"
      echo "  --orchest-dev   (default) launch Orchest via 'pnpm dev' with HMR"
      echo "  --orchest-prod  launch built Orchest from apps/desktop/out/ (lower memory)"
      exit 0
      ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

# ── Workspace definitions ────────────────────────────────────────────
# Format: ws|type|title|title_match|...
#   ghostty: ws|ghostty|title|title_match|workdir|command
#   cmux:    ws|cmux|title|title_match
#   chrome:  ws|chrome|title
# title_match is a regex used to find existing windows in AeroSpace.
# ws is the AeroSpace workspace to place the window in.
# Multiple entries can share a workspace (accordion layout toggles between them).
# Stray windows are swept to workspace "Z".
WORKSPACES=(
  "1|ghostty|Local MacOS|^Local MacOS$|~|while true; do nvim --cmd 'set title titlestring=Local\\ MacOS'; sleep 0.5; done"
  "1|chrome|Chrome: ws1"
  "T|ghostty|FTW: tunnels|FTW.*tunnels|~|nvs-tunnels devvm36111.ftw0.facebook.com FTW-main1 FTW-checkout1:~/checkout1/fbsource FTW-checkout2:~/checkout2/fbsource FTW-checkout3:~/checkout3/fbsource"
  "T|ghostty|CCO: tunnels|CCO.*tunnels|~|nvs-tunnels devvm20365.cco0.facebook.com CCO-main1 CCO-checkout1:~/checkout1/fbsource CCO-checkout2:~/checkout2/fbsource CCO-checkout3:~/checkout3/fbsource CCO-checkout4:~/checkout4/fbsource"
  "T|ghostty|Omnigent: tunnel|Omnigent.*tunnel|~|omnigent-tunnel"
  "2|ghostty|CCO: checkout1|CCO.*checkout1\\b|~|nvs CCO-checkout1"
  "2|chrome|Chrome: ws2"
  "3|ghostty|FTW: checkout1|FTW.*checkout1\\b|~|nvs FTW-checkout1"
  "3|chrome|Chrome: ws3"
  "4|ghostty|CCO: checkout2|CCO.*checkout2\\b|~|nvs CCO-checkout2"
  "4|chrome|Chrome: ws4"
  "5|ghostty|FTW: checkout2|FTW.*checkout2\\b|~|nvs FTW-checkout2"
  "5|chrome|Chrome: ws5"
  "6|ghostty|CCO: checkout3|CCO.*checkout3\\b|~|nvs CCO-checkout3"
  "6|chrome|Chrome: ws6"
  "7|ghostty|FTW: checkout3|FTW.*checkout3\\b|~|nvs FTW-checkout3"
  "7|chrome|Chrome: ws7"
  "8|ghostty|CCO: checkout4|CCO.*checkout4\\b|~|nvs CCO-checkout4"
  "8|chrome|Chrome: ws8"
)

SWEEP_WORKSPACE="Z"

CHROME_APP="Google Chrome"
CHROME_INVALID_TITLE_PATTERN="^Who.s using Chrome\\?$"
OMNIGENT_PORT="${OMNIGENT_PORT:-$(omnigent-server-url --port)}"
# ─────────────────────────────────────────────────────────────────────

# ── Window creation ─────────────────────────────────────────────────

create_ghostty_window() {
  local title="$1" workdir="$2" cmd="$3"
  workdir="${workdir/#\~/$HOME}"
  osascript \
    -e 'on run argv' \
    -e '  set theTitle to item 1 of argv' \
    -e '  set theWorkdir to item 2 of argv' \
    -e '  set theCmd to item 3 of argv' \
    -e '  set titleSeq to "printf '\''\\033]0;%s\\007'\'' " & quoted form of theTitle & " && exec zsh -lc " & quoted form of theCmd' \
    -e '  tell application "Ghostty"' \
    -e '    set cfg to new surface configuration' \
    -e '    set command of cfg to "zsh -lic " & quoted form of titleSeq' \
    -e '    set initial working directory of cfg to theWorkdir' \
    -e '    set wait after command of cfg to true' \
    -e '    set environment variables of cfg to {"GHOSTTY_WORKSPACE_TITLE=" & theTitle}' \
    -e '    new window with configuration cfg' \
    -e '  end tell' \
    -e 'end run' \
    -- "$title" "$workdir" "$cmd"
}

create_cmux_window() {
  if osascript -e 'application "cmux" is running' 2>/dev/null | grep -q 'true'; then
    return 0
  fi
  open -a cmux
}

# ── Helpers ──────────────────────────────────────────────────────────

managed_workspaces() {
  printf '%s\n' "${WORKSPACES[@]}" | cut -d'|' -f1 | sort -u
}

snapshot_windows() {
  aerospace list-windows --all --json 2>/dev/null
}

find_window_id() {
  local app_name="$1" title_substr="$2" snapshot="$3"
  echo "$snapshot" | jq -r \
    --arg app "$app_name" \
    --arg title "$title_substr" \
    '[.[] | select(."app-name" == $app and (.["window-title"] | test($title; "i")))] | first | .["window-id"] // empty'
}

find_window_id_for_workspace() {
  local app_name="$1" title_substr="$2" ws="$3" snapshot="$4"
  local window_id

  window_id=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null \
    | jq -r \
      --arg app "$app_name" \
      --arg title "$title_substr" \
      '[.[] | select(."app-name" == $app and (.["window-title"] | test($title; "i")))] | first | .["window-id"] // empty') || true
  if [[ -n "$window_id" ]]; then
    echo "$window_id"
    return 0
  fi

  find_window_id "$app_name" "$title_substr" "$snapshot"
}

get_focused_window_id() {
  aerospace list-windows --focused --json 2>/dev/null | jq -r '.[0]["window-id"] // empty'
}

window_exists() {
  local wid="$1"
  aerospace list-windows --all --json 2>/dev/null \
    | jq -e --argjson wid "$wid" \
      '[.[] | select(.["window-id"] == $wid)] | length > 0' >/dev/null
}

close_window_id() {
  local wid="$1" reason="$2"
  echo "Closing ${reason} window $wid..."
  aerospace close --window-id "$wid" 2>/dev/null || true
  for _ in $(seq 1 20); do
    sleep 0.2
    window_exists "$wid" || return 0
  done

  echo "WARNING: ${reason} window $wid did not close" >&2
  return 1
}

tunnel_command_is_current() {
  local host="$1"
  local cmds
  # We need the complete command line to inspect its tunnel flags.
  # shellcheck disable=SC2009
  cmds=$(ps -axo command | grep -F "x2ssh -et $host" | grep -v grep || true)

  # If the tunnel is between x2ssh attempts (Duo/reconnect), don't churn the
  # Ghostty window. We only know it is stale when a live x2ssh command is using
  # the old reverse-forward set.
  [[ -z "$cmds" ]] && return 0

  echo "$cmds" \
    | grep -F -- "-r " \
    | grep -Fv ",${OMNIGENT_PORT}:${OMNIGENT_PORT}" >/dev/null
}

stop_tunnel_processes_for_host() {
  local host="$1"
  local pids

  pids=$(ps -axo pid,command | awk -v host="$host" '
    index($0, "nvs-tunnels " host) ||
    index($0, "x2ssh -et " host) ||
    index($0, "fallback " host) ||
    index($0, "HostName=" host) {
      print $1
    }
  ') || true

  [[ -z "$pids" ]] && return 0
  echo "Stopping stale tunnel process(es) for $host: $(echo "$pids" | tr '\n' ' ')"
  # pids is an intentional whitespace-delimited list produced by awk.
  # shellcheck disable=SC2086
  kill $pids 2>/dev/null || true
}

close_stale_tunnel_window_if_needed() {
  local wid="$1" title="$2" cmd="$3"
  local _nvs host _rest

  [[ "$cmd" == nvs-tunnels\ * ]] || return 1
  read -r _nvs host _rest <<< "$cmd"
  [[ -n "$host" ]] || return 1

  if tunnel_command_is_current "$host"; then
    return 1
  fi

  echo "[$title] existing NVS tunnel is stale for $host; recreating it..."
  close_window_id "$wid" "stale tunnel"
  stop_tunnel_processes_for_host "$host"
}

wait_for_new_window() {
  local app_name="$1" before_snapshot="$2"
  local before_ids
  before_ids=$(echo "$before_snapshot" | jq -r \
    --arg app "$app_name" \
    '[.[] | select(."app-name" == $app)] | .[]["window-id"]' | sort -n)

  for _ in $(seq 1 20); do
    sleep 0.5
    local current_snapshot current_ids new_id
    current_snapshot=$(snapshot_windows)
    current_ids=$(echo "$current_snapshot" | jq -r \
      --arg app "$app_name" \
      '[.[] | select(."app-name" == $app)] | .[]["window-id"]' | sort -n)
    new_id=$(comm -23 <(echo "$current_ids") <(echo "$before_ids") | head -1)
    if [[ -n "$new_id" ]]; then
      echo "$new_id"
      return 0
    fi
  done
  return 1
}

find_valid_chrome_window_on_workspace() {
  local ws="$1"
  aerospace list-windows --workspace "$ws" --json 2>/dev/null \
    | jq -r --arg app "$CHROME_APP" --arg invalid "$CHROME_INVALID_TITLE_PATTERN" \
      '[.[] | select(
        ."app-name" == $app and
        ((.["window-title"] // "") | test($invalid) | not)
      )] | first | .["window-id"] // empty'
}

close_invalid_chrome_windows_on_workspace() {
  local ws="$1"
  local invalid_ids wid
  invalid_ids=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null \
    | jq -r --arg app "$CHROME_APP" --arg invalid "$CHROME_INVALID_TITLE_PATTERN" \
      '.[] | select(
        ."app-name" == $app and
        ((.["window-title"] // "") | test($invalid))
      ) | .["window-id"]') || true

  for wid in $invalid_ids; do
    [[ -z "$wid" ]] && continue
    echo "Closing invalid Chrome window $wid from workspace $ws..."
    aerospace focus --window-id "$wid" 2>/dev/null || true
    if [[ "$(get_focused_window_id)" == "$wid" ]]; then
      aerospace close 2>/dev/null || true
    else
      echo "WARNING: could not focus invalid Chrome window $wid; moving it to $SWEEP_WORKSPACE" >&2
      aerospace move-node-to-workspace --window-id "$wid" "$SWEEP_WORKSPACE" 2>/dev/null || true
    fi
  done
}

# Poll until every WORKSPACES entry has at least one matching window
# present anywhere. wait_for_new_window in the main loop has a 10s
# timeout, but app windows can take longer to appear and titles may still
# be loading after the window exists. arrange-workspaces is
# destructive (flatten + rebuild) and produces unrecoverable layouts
# when the expected window set is incomplete — e.g. a workspace with
# only Orchest + one app window present hits the single-accordion-window
# scaffold branch, then a late Ghostty/Chrome arrival triggers
# a layout rebuild and the resulting `move` calls can create unwanted nesting.
# Returns 0 if all entries are satisfied within the timeout, 1 otherwise.
wait_for_expected_windows() {
  local timeout="${1:-30}"
  local deadline=$(($(date +%s) + timeout))

  while [[ $(date +%s) -lt $deadline ]]; do
    local snapshot all_present=true
    snapshot=$(snapshot_windows)

    for entry in "${WORKSPACES[@]}"; do
      IFS='|' read -r _ws type _title rest <<< "$entry"
      local app_name title_match
      case "$type" in
        ghostty) IFS='|' read -r title_match _ <<< "$rest"; app_name="Ghostty" ;;
        cmux)    title_match="."; app_name="cmux" ;;
        *)       continue ;;
      esac

      local found
      found=$(echo "$snapshot" | jq -r \
        --arg app "$app_name" --arg pat "$title_match" \
        '[.[] | select(."app-name" == $app and (.["window-title"] | test($pat; "i")))] | length')
      if [[ "$found" -lt 1 ]]; then
        all_present=false
        break
      fi
    done

    $all_present && return 0
    sleep 0.5
  done
  return 1
}

reconcile_expected_managed_windows_once() {
  local snapshot entry ws type title rest app_name title_match window_id already
  RECONCILE_MISSING=0
  RECONCILE_MOVED=0
  matched_ids=()
  snapshot=$(snapshot_windows)

  for entry in "${WORKSPACES[@]}"; do
    IFS='|' read -r ws type title rest <<< "$entry"
    case "$type" in
      ghostty)
        IFS='|' read -r title_match _ <<< "$rest"
        app_name="Ghostty"
        ;;
      cmux)
        title_match="."
        app_name="cmux"
        ;;
      *) continue ;;
    esac

    window_id=$(find_window_id_for_workspace "$app_name" "$title_match" "$ws" "$snapshot")
    if [[ -z "$window_id" ]]; then
      RECONCILE_MISSING=$(( RECONCILE_MISSING + 1 ))
      continue
    fi
    matched_ids+=("$window_id")

    already=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null \
      | jq -r --argjson wid "$window_id" \
        '[.[] | select(.["window-id"] == $wid)] | first | .["window-id"] // empty') || true
    if [[ -z "$already" ]]; then
      echo "[$title] relocating to workspace $ws..."
      if aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null; then
        RECONCILE_MOVED=$(( RECONCILE_MOVED + 1 ))
      else
        echo "WARNING: [$title] relocate failed" >&2
      fi
    fi
  done
}

reconcile_expected_managed_windows() {
  local timeout="${1:-20}"
  local deadline=$(($(date +%s) + timeout))

  while true; do
    reconcile_expected_managed_windows_once
    if [[ "$RECONCILE_MISSING" -eq 0 && "$RECONCILE_MOVED" -eq 0 ]]; then
      return 0
    fi

    if [[ $(date +%s) -ge $deadline ]]; then
      return 1
    fi
    sleep 0.5
  done
}

# ── Main ─────────────────────────────────────────────────────────────

# Prevent auto-accordion callback from interfering during startup
touch /tmp/startup-windows.lock
trap 'rm -f /tmp/startup-windows.lock' EXIT

if ! command -v aerospace &>/dev/null; then
  echo "ERROR: aerospace CLI not found." >&2
  echo "Install AeroSpace: brew install --cask nikitabobko/tap/aerospace" >&2
  exit 1
fi

if ! aerospace list-windows --all &>/dev/null; then
  echo "ERROR: AeroSpace is not running." >&2
  echo "Start AeroSpace.app first." >&2
  exit 1
fi

# Ensure Ghostty is running (but don't close its default window).
# Ghostty creates a default window on launch. We leave it open so the
# SNAPSHOT captures it — this prevents wait_for_new_window from
# misidentifying it as a newly created window. The reconciliation pass
# at the end sweeps it to workspace Z.
if ! osascript -e 'application "Ghostty" is running' 2>/dev/null | grep -q 'true'; then
  open -a Ghostty
  sleep 2
fi

# Snapshot all windows
SNAPSHOT=$(snapshot_windows)

failures=0

# The dedicated Omnigent ET forward exposes the active hub on Mac loopback. An
# existing tunnel satisfies this preflight; on a cold start the tunnel window
# created below repairs it.
if ! curl -sf "http://127.0.0.1:${OMNIGENT_PORT}/health" >/dev/null 2>&1; then
  echo "Omnigent hub tunnel is not healthy yet at http://127.0.0.1:${OMNIGENT_PORT}; the tunnel bootstrap will retry it" >&2
fi

for i in "${!WORKSPACES[@]}"; do
  IFS='|' read -r ws type title rest <<< "${WORKSPACES[$i]}"

  case "$type" in
    ghostty)
      IFS='|' read -r title_match workdir cmd <<< "$rest"
      app_name="Ghostty"

      window_id=$(find_window_id_for_workspace "$app_name" "$title_match" "$ws" "$SNAPSHOT")
      if [[ -n "$window_id" ]] && close_stale_tunnel_window_if_needed "$window_id" "$title" "$cmd"; then
        SNAPSHOT=$(snapshot_windows)
        window_id=""
      fi

      if [[ -n "$window_id" ]]; then
        echo "[$title] moving existing window to workspace $ws..."
        aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || {
          echo "WARNING: [$title] move failed" >&2
          ((failures++)) || true
        }
      else
        echo "[$title] creating on workspace $ws..."
        before_snapshot="$SNAPSHOT"
        create_ghostty_window "$title" "$workdir" "$cmd" || {
          echo "WARNING: [$title] creation failed, skipping" >&2
          ((failures++)) || true
          continue
        }
        window_id=$(wait_for_new_window "$app_name" "$before_snapshot") || {
          # Fallback: try the focused window
          window_id=$(get_focused_window_id)
        }
        if [[ -n "$window_id" ]]; then
          aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || true
        else
          echo "WARNING: [$title] could not find new window ID" >&2
          ((failures++)) || true
        fi
        # Update snapshot for subsequent iterations
        SNAPSHOT=$(snapshot_windows)
      fi
      ;;
    cmux)
      IFS='|' read -r title_match _ <<< "$rest"
      app_name="cmux"

      window_id=$(find_window_id_for_workspace "$app_name" "$title_match" "$ws" "$SNAPSHOT")
      if [[ -n "$window_id" ]]; then
        echo "[$title] moving existing window to workspace $ws..."
        aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || {
          echo "WARNING: [$title] move failed" >&2
          ((failures++)) || true
        }
      else
        echo "[$title] creating on workspace $ws..."
        before_snapshot="$SNAPSHOT"
        create_cmux_window || {
          echo "WARNING: [$title] creation failed, skipping" >&2
          ((failures++)) || true
          continue
        }
        window_id=$(wait_for_new_window "$app_name" "$before_snapshot") || {
          window_id=$(get_focused_window_id)
        }
        if [[ -n "$window_id" ]]; then
          aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || true
        else
          echo "WARNING: [$title] could not find new window ID" >&2
          ((failures++)) || true
        fi
        SNAPSHOT=$(snapshot_windows)
      fi
      ;;
    chrome)
      app_name="$CHROME_APP"

      # Profile-picker windows are Chrome windows, but they do not satisfy the
      # workspace contract. Close them so we create/reuse a real profile window.
      close_invalid_chrome_windows_on_workspace "$ws"

      # Check if a usable Chrome window already exists on this workspace.
      existing=$(find_valid_chrome_window_on_workspace "$ws") || true
      if [[ -n "$existing" ]]; then
        echo "[$title] Chrome already on workspace $ws"
      else
        echo "[$title] creating on workspace $ws..."
        before_snapshot="$SNAPSHOT"
        open -na "$CHROME_APP" --args --profile-directory=Default --new-window 2>/dev/null || {
          echo "WARNING: [$title] creation failed, skipping" >&2
          ((failures++)) || true
          continue
        }
        window_id=$(wait_for_new_window "$app_name" "$before_snapshot") || {
          window_id=$(get_focused_window_id)
        }
        if [[ -n "$window_id" ]]; then
          aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || true
        else
          echo "WARNING: [$title] could not find new Chrome window" >&2
          ((failures++)) || true
        fi
        SNAPSHOT=$(snapshot_windows)
      fi
      ;;
  esac
done

# ── Orchest ──────────────────────────────────────────────────────────

orchest-open-workspaces ${ORCHEST_MODE_FLAG:+$ORCHEST_MODE_FLAG} || {
  echo "WARNING: orchest-open-workspaces failed" >&2
  ((failures++)) || true
}

# ── Wait for late-appearing windows ──────────────────────────────────

echo "Waiting up to 30s for any late-appearing windows..."
if wait_for_expected_windows 30; then
  echo "All expected windows present."
else
  echo "WARNING: some expected windows did not appear within 30s; layout may be incomplete" >&2
  ((failures++)) || true
fi

# ── Reconciliation pass ───────────────────────────────────────────────
# Relocate windows that appeared after their wait_for_new_window timed
# out, and sweep unmatched Ghostty windows from managed
# workspaces (e.g. the default Ghostty window created on launch).

swept=0
if ! reconcile_expected_managed_windows 20; then
  echo "WARNING: some expected managed windows were still missing or moving after reconciliation" >&2
  ((failures++)) || true
fi

# Sweep unmatched Ghostty windows from managed workspaces
matched_pattern=$(printf '%s\n' "${matched_ids[@]}" | jq -R -s 'split("\n") | map(select(. != "") | tonumber)')
for ws in $(managed_workspaces); do
  stray_ids=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null \
    | jq -r --argjson matched "$matched_pattern" \
      '[.[] | select(
        ."app-name" == "Ghostty" and
        (.["window-id"] | IN($matched[]) | not)
      )] | .[]["window-id"]') || true
  for wid in $stray_ids; do
    [[ -z "$wid" ]] && continue
    echo "Sweeping unmatched window $wid from workspace $ws to $SWEEP_WORKSPACE..."
    if aerospace move-node-to-workspace --window-id "$wid" "$SWEEP_WORKSPACE" 2>/dev/null; then
      ((swept++)) || true
    fi
  done
done

# ─────────────────────────────────────────────────────────────────────

# Close invalid Chrome windows from managed workspaces. They can be restored by
# Chrome after the per-workspace checks above, and otherwise look like valid app
# windows to the generic stray sweep.
for ws in $(managed_workspaces); do
  close_invalid_chrome_windows_on_workspace "$ws"
done
close_invalid_chrome_windows_on_workspace "$SWEEP_WORKSPACE"

# Sweep stray windows: move unrecognized windows off managed workspaces to Z
for ws in $(managed_workspaces); do
  stray_ids=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null \
    | jq -r --arg chrome "$CHROME_APP" \
      '[.[] | select(
        ."app-name" != "Ghostty" and
        ."app-name" != "cmux" and
        ."app-name" != $chrome and
        (.["window-title"] | test("Orchest \\[") | not)
      )] | .[]["window-id"]') || true
  for wid in $stray_ids; do
    [[ -z "$wid" ]] && continue
    if aerospace move-node-to-workspace --window-id "$wid" "$SWEEP_WORKSPACE" 2>/dev/null; then
      ((swept++)) || true
    fi
  done
done

if [[ "$swept" -gt 0 ]]; then
  echo "Swept ${swept} stray window(s) to workspace ${SWEEP_WORKSPACE}."
fi

# Arrange layouts (tiles | accordion) on managed workspaces
# managed_workspaces intentionally expands to separate workspace arguments.
# shellcheck disable=SC2046
ARRANGE_ATTEMPTS=8 ARRANGE_RETRY_SLEEP=1 arrange-workspaces --force $(managed_workspaces) || {
  echo "WARNING: arrange-workspaces did not converge" >&2
  ((failures++)) || true
}

# If auto-accordion is re-enabled, it should do a full rebuild for any window
# that appears after this point, so no drain sleep is needed here.

# Focus workspace 1
aerospace workspace 1 2>/dev/null || true

# Trigger SketchBar reconciliation so items are created for any workspaces
# that appeared after SketchBar's initial sync (T, Z, Orchest workspaces, etc.)
sketchybar --trigger aerospace_reconcile 2>/dev/null || true

if [[ "$failures" -gt 0 ]]; then
  echo "Done with ${failures} warning(s)."
else
  echo "Done."
fi
