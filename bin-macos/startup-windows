#!/usr/bin/env bash
set -euo pipefail

# ── Workspace definitions ────────────────────────────────────────────
# Format: ws|type|title|title_match|...
#   ghostty: ws|ghostty|title|title_match|workdir|command
#   cmux:    ws|cmux|title|title_match
#   vscode:  ws|vscode|title|title_match|workspace (local path or remote URI)
# title_match is a regex used to find existing windows in AeroSpace.
# ws is the AeroSpace workspace to place the window in.
# Multiple entries can share a workspace (accordion layout toggles between them).
# Stray windows are swept to workspace "Z".
WORKSPACES=(
  "1|cmux|Local MacOS|."
  "T|ghostty|FTW: tunnels|FTW.*tunnels|~|nvs-tunnels devvm36111.ftw0.facebook.com FTW-main1 FTW-fbsource1:~/fbsource FTW-fbsource2:~/fbsource2"
  "T|ghostty|CCO: tunnels|CCO.*tunnels|~|nvs-tunnels devvm20365.cco0.facebook.com CCO-main1 CCO-fbsource1:~/fbsource CCO-fbsource2:~/fbsource2"
  "2|ghostty|FTW: main1|FTW.*main1|~|nvs FTW-main1"
  "3|ghostty|FTW: fbsource1|FTW.*fbsource1|~|nvs FTW-fbsource1"
  "3|vscode|FTW: vscode-fbsource1|devvm36111.ftw0 \\(Workspace\\)|${HOME}/Library/Application Support/VS Code @ FB/MetaWorkspaces/devvm36111.ftw0.code-workspace"
  "4|ghostty|FTW: fbsource2|FTW.*fbsource2|~|nvs FTW-fbsource2"
  "4|vscode|FTW: vscode-fbsource2|fbsource2.*devvm36111.ftw0|vscode-remote://fb-remote+devvm36111.ftw0.facebook.com/home/mkarrmann/fbsource2.code-workspace"
  "5|ghostty|CCO: main1|CCO.*main1|~|nvs CCO-main1"
  "6|ghostty|CCO: fbsource1|CCO.*fbsource1|~|nvs CCO-fbsource1"
  "6|vscode|CCO: vscode-fbsource1|devvm20365.cco0 \\(Workspace\\)|${HOME}/Library/Application Support/VS Code @ FB/MetaWorkspaces/devvm20365.cco0.code-workspace"
  "7|ghostty|CCO: fbsource2|CCO.*fbsource2|~|nvs CCO-fbsource2"
  "7|vscode|CCO: vscode-fbsource2|fbsource2.*devvm20365.cco0|vscode-remote://fb-remote+devvm20365.cco0.facebook.com/home/mkarrmann/fbsource2.code-workspace"
)

SWEEP_WORKSPACE="Z"

VSCODE_APP_AEROSPACE="VS Code @ Meta"
VSCODE_APP_MACOS="VS Code @ FB"
VSCODE_CMD="/Applications/VS Code @ FB.app/Contents/Resources/app/bin/code"
# ─────────────────────────────────────────────────────────────────────

# ── Window creation ─────────────────────────────────────────────────

create_ghostty_window() {
  local title="$1" workdir="$2" cmd="$3"
  workdir="${workdir/#\~/$HOME}"
  osascript \
    -e 'on run argv' \
    -e '  set theTitle to item 1 of argv' \
    -e '  set theWorkdir to item 2 of argv' \
    -e '  set theCmd to item 3 of argv' \
    -e '  set titleSeq to "printf '\''\\033]0;%s\\007'\'' " & quoted form of theTitle & " && exec " & theCmd' \
    -e '  tell application "Ghostty"' \
    -e '    set cfg to new surface configuration' \
    -e '    set command of cfg to "zsh -lic " & quoted form of titleSeq' \
    -e '    set initial working directory of cfg to theWorkdir' \
    -e '    set wait after command of cfg to true' \
    -e '    set environment variables of cfg to {"GHOSTTY_WORKSPACE_TITLE=" & theTitle}' \
    -e '    new window with configuration cfg' \
    -e '  end tell' \
    -e 'end run' \
    -- "$title" "$workdir" "$cmd"
}

create_cmux_window() {
  if osascript -e 'application "cmux" is running' 2>/dev/null | grep -q 'true'; then
    return 0
  fi
  open -a cmux
}

create_vscode_window() {
  local workspace="$1"
  if [[ "$workspace" == vscode-remote://* ]]; then
    "$VSCODE_CMD" --file-uri "$workspace" -n 2>/dev/null
  else
    "$VSCODE_CMD" "$workspace" -n 2>/dev/null
  fi
}

# ── Helpers ──────────────────────────────────────────────────────────

managed_workspaces() {
  printf '%s\n' "${WORKSPACES[@]}" | cut -d'|' -f1 | sort -u
}

snapshot_windows() {
  aerospace list-windows --all --json 2>/dev/null
}

find_window_id() {
  local app_name="$1" title_substr="$2" snapshot="$3"
  echo "$snapshot" | jq -r \
    --arg app "$app_name" \
    --arg title "$title_substr" \
    '[.[] | select(."app-name" == $app and (.["window-title"] | test($title; "i")))] | first | .["window-id"] // empty'
}

get_focused_window_id() {
  aerospace list-windows --focused --json 2>/dev/null | jq -r '.[0]["window-id"] // empty'
}

wait_for_new_window() {
  local app_name="$1" before_snapshot="$2"
  local before_ids
  before_ids=$(echo "$before_snapshot" | jq -r \
    --arg app "$app_name" \
    '[.[] | select(."app-name" == $app)] | .[]["window-id"]' | sort -n)

  for _ in $(seq 1 20); do
    sleep 0.5
    local current_snapshot current_ids new_id
    current_snapshot=$(snapshot_windows)
    current_ids=$(echo "$current_snapshot" | jq -r \
      --arg app "$app_name" \
      '[.[] | select(."app-name" == $app)] | .[]["window-id"]' | sort -n)
    new_id=$(comm -23 <(echo "$current_ids") <(echo "$before_ids") | head -1)
    if [[ -n "$new_id" ]]; then
      echo "$new_id"
      return 0
    fi
  done
  return 1
}

# ── Main ─────────────────────────────────────────────────────────────

if ! command -v aerospace &>/dev/null; then
  echo "ERROR: aerospace CLI not found." >&2
  echo "Install AeroSpace: brew install --cask nikitabobko/tap/aerospace" >&2
  exit 1
fi

# Ensure Ghostty is running
if ! osascript -e 'application "Ghostty" is running' 2>/dev/null | grep -q 'true'; then
  open -a Ghostty
  sleep 2
  osascript -e 'tell application "Ghostty" to close window 1' 2>/dev/null || true
fi

# Ensure VS Code is running if any vscode workspaces are defined
has_vscode=false
for entry in "${WORKSPACES[@]}"; do
  if [[ "$entry" == vscode\|* ]]; then has_vscode=true; break; fi
done
if $has_vscode; then
  if ! osascript -e "application \"${VSCODE_APP_MACOS}\" is running" 2>/dev/null | grep -q 'true'; then
    open -a "$VSCODE_APP_MACOS"
    sleep 3
  fi
fi

# Snapshot all windows
SNAPSHOT=$(snapshot_windows)

failures=0

for i in "${!WORKSPACES[@]}"; do
  IFS='|' read -r ws type title rest <<< "${WORKSPACES[$i]}"

  case "$type" in
    ghostty)
      IFS='|' read -r title_match workdir cmd <<< "$rest"
      app_name="Ghostty"

      window_id=$(find_window_id "$app_name" "$title_match" "$SNAPSHOT")
      if [[ -n "$window_id" ]]; then
        echo "[$title] moving existing window to workspace $ws..."
        aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || {
          echo "WARNING: [$title] move failed" >&2
          ((failures++)) || true
        }
      else
        echo "[$title] creating on workspace $ws..."
        before_snapshot="$SNAPSHOT"
        create_ghostty_window "$title" "$workdir" "$cmd" || {
          echo "WARNING: [$title] creation failed, skipping" >&2
          ((failures++)) || true
          continue
        }
        window_id=$(wait_for_new_window "$app_name" "$before_snapshot") || {
          # Fallback: try the focused window
          window_id=$(get_focused_window_id)
        }
        if [[ -n "$window_id" ]]; then
          aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || true
        else
          echo "WARNING: [$title] could not find new window ID" >&2
          ((failures++)) || true
        fi
        # Update snapshot for subsequent iterations
        SNAPSHOT=$(snapshot_windows)
      fi
      ;;
    cmux)
      IFS='|' read -r title_match _ <<< "$rest"
      app_name="cmux"

      window_id=$(find_window_id "$app_name" "$title_match" "$SNAPSHOT")
      if [[ -n "$window_id" ]]; then
        echo "[$title] moving existing window to workspace $ws..."
        aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || {
          echo "WARNING: [$title] move failed" >&2
          ((failures++)) || true
        }
      else
        echo "[$title] creating on workspace $ws..."
        before_snapshot="$SNAPSHOT"
        create_cmux_window || {
          echo "WARNING: [$title] creation failed, skipping" >&2
          ((failures++)) || true
          continue
        }
        window_id=$(wait_for_new_window "$app_name" "$before_snapshot") || {
          window_id=$(get_focused_window_id)
        }
        if [[ -n "$window_id" ]]; then
          aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || true
        else
          echo "WARNING: [$title] could not find new window ID" >&2
          ((failures++)) || true
        fi
        SNAPSHOT=$(snapshot_windows)
      fi
      ;;
    vscode)
      IFS='|' read -r title_match workspace <<< "$rest"
      app_name="$VSCODE_APP_AEROSPACE"

      window_id=$(find_window_id "$app_name" "$title_match" "$SNAPSHOT")
      if [[ -n "$window_id" ]]; then
        echo "[$title] moving existing window to workspace $ws..."
        aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || {
          echo "WARNING: [$title] move failed" >&2
          ((failures++)) || true
        }
      else
        echo "[$title] creating on workspace $ws..."
        before_snapshot="$SNAPSHOT"
        create_vscode_window "$workspace" || {
          echo "WARNING: [$title] creation failed, skipping" >&2
          ((failures++)) || true
          continue
        }
        window_id=$(wait_for_new_window "$app_name" "$before_snapshot") || {
          echo "WARNING: [$title] window did not appear in time" >&2
          ((failures++)) || true
          continue
        }
        if [[ -n "$window_id" ]]; then
          aerospace move-node-to-workspace --window-id "$window_id" "$ws" 2>/dev/null || true
        fi
        # Update snapshot for subsequent iterations
        SNAPSHOT=$(snapshot_windows)
      fi
      ;;
  esac
done

# Set accordion layout on workspaces with multiple windows
for ws in $(managed_workspaces); do
  win_count=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null | jq 'length')
  if [[ "$win_count" -gt 1 ]]; then
    aerospace workspace "$ws" 2>/dev/null || true
    aerospace flatten-workspace-tree 2>/dev/null || true
    aerospace layout accordion vertical 2>/dev/null || true
  fi
done

# Sweep stray windows: move non-Ghostty/VS Code windows off workspaces 1-9,A,B to Z
swept=0
for ws in $(managed_workspaces); do
  stray_ids=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null \
    | jq -r --arg vscode "$VSCODE_APP_AEROSPACE" \
      '[.[] | select(."app-name" != "Ghostty" and ."app-name" != "cmux" and ."app-name" != $vscode)] | .[]["window-id"]') || true
  for wid in $stray_ids; do
    [[ -z "$wid" ]] && continue
    aerospace move-node-to-workspace --window-id "$wid" "$SWEEP_WORKSPACE" 2>/dev/null && ((swept++)) || true
  done
done

if [[ "$swept" -gt 0 ]]; then
  echo "Swept ${swept} stray window(s) to workspace ${SWEEP_WORKSPACE}."
fi

# Focus workspace 1
aerospace workspace 1 2>/dev/null || true

if [[ "$failures" -gt 0 ]]; then
  echo "Done with ${failures} warning(s)."
else
  echo "Done."
fi
