#!/usr/bin/env bash
set -euo pipefail

# Do not let one wedged AeroSpace IPC client freeze workspace startup. Layout
# verification already retries the whole operation, so timed-out mutations are
# safely observed and corrected by the next pass.
AEROSPACE_COMMAND_TIMEOUT="${AEROSPACE_COMMAND_TIMEOUT:-8}"
AEROSPACE_TIMEOUT_BIN="$(command -v timeout || command -v gtimeout || true)"
AEROSPACE_BIN="$(command -v aerospace || true)"

aerospace() {
  local attempts=1 attempt=1 output status
  case "${1:-}" in
    list-*) attempts=3 ;;
  esac

  while [[ "$attempt" -le "$attempts" ]]; do
    if [[ -n "$AEROSPACE_TIMEOUT_BIN" ]]; then
      if output=$("$AEROSPACE_TIMEOUT_BIN" --foreground --kill-after=1 \
          "$AEROSPACE_COMMAND_TIMEOUT" "$AEROSPACE_BIN" "$@"); then
        printf '%s' "$output"
        return 0
      else
        status=$?
      fi
    else
      if output=$("$AEROSPACE_BIN" "$@"); then
        printf '%s' "$output"
        return 0
      else
        status=$?
      fi
    fi
    if [[ "$status" -eq 124 || "$status" -eq 137 ]]; then
      echo "WARNING: AeroSpace command timed out: aerospace $*" >&2
    fi
    attempt=$(( attempt + 1 ))
    [[ "$attempt" -le "$attempts" ]] && sleep 0.25
  done
  return "$status"
}

# arrange-workspaces: On each workspace, put Orchest windows as tiles on the
# left (sidebar) and all other windows in an accordion on the right.
# If a workspace has no Orchest windows, it stays as a flat accordion.
# Skips workspaces whose window set hasn't changed since last arrangement
# to preserve manual size adjustments. Use --force to override.
# Can be run standalone or called from startup-windows.
#
# Requires enable-normalization-flatten-containers = false so that
# single-child accordion containers persist without being auto-collapsed.
#
# AeroSpace gotchas this script works around:
#   - default-root-container-layout is 'accordion', so flatten-workspace-tree
#     resets root to accordion. We immediately override with tiles horizontal.
#   - `layout accordion` on a direct child of root changes the ROOT layout,
#     not the child's. Only use it on windows inside a nested container.
#
# Debugging: check layout state with:
#   aerospace list-windows --workspace N --format \
#     '%{window-id} %{app-name} | parent=%{window-parent-container-layout} | root=%{workspace-root-container-layout}'

SIDEBAR_TITLE_PATTERN="Orchest \\["
SIDEBAR_PERCENT=12
MARKER_DIR="/tmp/aerospace-arrange-markers"
ARRANGE_ATTEMPTS="${ARRANGE_ATTEMPTS:-5}"
ARRANGE_RETRY_SLEEP="${ARRANGE_RETRY_SLEEP:-1}"
FORCE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force|-f) FORCE=true; shift ;;
    *) break ;;
  esac
done

mkdir -p "$MARKER_DIR"

get_screen_width() {
  osascript -l JavaScript -e \
    'ObjC.import("AppKit"); $.NSScreen.mainScreen.frame.size.width' 2>/dev/null || echo 0
}

# Idempotently set the accordion column to (100 - SIDEBAR_PERCENT)% of the main
# screen width via an ABSOLUTE resize (no +/-). A fixed +delta nudge computed on
# one monitor does not survive a move to a different-size monitor, so on a
# monitor change the split silently overflows; an absolute target self-corrects
# to whatever monitor the workspace currently lives on. Works on hidden
# workspaces (no focus needed) and is safe to call on an already-correct layout.
enforce_split() {
  local first_accordion="$1"
  [[ -n "$first_accordion" ]] || return 0
  local accordion_percent=$((100 - SIDEBAR_PERCENT))
  [[ "$accordion_percent" -ne 50 ]] || return 0
  local screen_width
  screen_width=$(get_screen_width)
  [[ "$screen_width" -gt 0 ]] || return 0
  local target=$(( screen_width * accordion_percent / 100 ))
  # Orchest windows won't shrink below ~300px. On narrow monitors the sidebar's
  # (100 - accordion_percent)% slice falls below that floor, so the sidebar keeps
  # its minimum while the absolute accordion target overflows and overlaps it.
  # Cap the accordion so the remainder always covers the sidebar minimum.
  local min_sidebar=300
  local max_accordion=$(( screen_width - min_sidebar ))
  [[ "$target" -gt "$max_accordion" ]] && target="$max_accordion"
  aerospace resize --window-id "$first_accordion" width "$target" 2>/dev/null || true
}

workspace_fingerprint() {
  local windows="$1"
  echo "$windows" | jq -r '.[] | "\(.["window-id"]):\(.["app-name"])"' | sort | md5 -q
}

# Try to focus a window by ID and verify focus actually landed there.
# `aerospace focus --window-id` can silently land focus on a *different*
# window when the target is phantom/transient (observed with cmux
# occasionally reporting `window-id 0`, which AeroSpace treats as a
# sentinel — focusing it from various neighbors lands on whichever window
# AeroSpace picks, not 0). Such windows also break spatial navigation
# (`focus left/right` wraps past them even with `--boundaries-action stop`)
# and confuse join-with/move. The only reliable test is to attempt the
# focus and verify the result.
focus_verified() {
  local wid="$1"
  aerospace focus --window-id "$wid" 2>/dev/null || true
  local actual
  actual=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
  [[ "$actual" == "$wid" ]]
}

# Move any window on $ws that fails focus_verified to workspace Z.
# Returns the number of windows swept (via stdout).
sweep_unfocusable() {
  local ws="$1" windows_json="$2"
  local swept=0 wid
  aerospace workspace "$ws" 2>/dev/null || true
  for wid in $(echo "$windows_json" | jq -r '.[]["window-id"]'); do
    if ! focus_verified "$wid"; then
      sleep 0.2
    fi
    if ! focus_verified "$wid"; then
      sleep 0.5
    fi
    if ! focus_verified "$wid"; then
      echo "  [$ws] sweeping unfocusable window $wid → Z" >&2
      aerospace move-node-to-workspace --window-id "$wid" Z 2>/dev/null || true
      swept=$(( swept + 1 ))
    fi
  done
  echo "$swept"
}

# Check whether $ws is already in the desired tree shape. Returns 0 if
# correct, 1 otherwise.
#
# Desired:
#   - Mixed sidebar+accordion: root = h_tiles; sidebar windows have
#     parent = h_tiles (either root, or an h_tiles sub-container when
#     there are multiple sidebars); accordion windows have parent =
#     v_accordion (a single sub-container).
#   - Accordion-only: every window has parent = v_accordion.
layout_tree_correct() {
  local ws="$1" sidebar_ids="$2" accordion_ids="$3"

  local id_to_parent
  id_to_parent=$(aerospace list-windows --workspace "$ws" \
    --format '%{window-id}|%{window-parent-container-layout}' 2>/dev/null) || return 1

  local wid parent

  # Accordion-only: every window's parent is v_accordion
  if [[ -z "$sidebar_ids" ]]; then
    for wid in $accordion_ids; do
      parent=$(echo "$id_to_parent" | awk -F'|' -v w="$wid" '$1==w {print $2; exit}')
      [[ "$parent" == "v_accordion" ]] || return 1
    done
    return 0
  fi

  # Mixed: root must be h_tiles
  local root_layout
  root_layout=$(aerospace list-windows --workspace "$ws" \
    --format '%{workspace-root-container-layout}' 2>/dev/null | head -1)
  [[ "$root_layout" == "h_tiles" ]] || return 1

  for wid in $sidebar_ids; do
    parent=$(echo "$id_to_parent" | awk -F'|' -v w="$wid" '$1==w {print $2; exit}')
    [[ "$parent" == "h_tiles" ]] || return 1
  done
  for wid in $accordion_ids; do
    parent=$(echo "$id_to_parent" | awk -F'|' -v w="$wid" '$1==w {print $2; exit}')
    [[ "$parent" == "v_accordion" ]] || return 1
  done
  return 0
}

# Check spatial order for the mixed layout: all sidebar windows must be left of
# all accordion windows. This closes the gap left by parent-layout checks alone.
layout_order_correct() {
  local ws="$1" sidebar_ids="$2" accordion_ids="$3"

  [[ -z "$sidebar_ids" || -z "$accordion_ids" ]] && return 0

  local first_sidebar
  first_sidebar=$(echo "$sidebar_ids" | head -1)

  aerospace workspace "$ws" 2>/dev/null || true
  focus_verified "$first_sidebar" || return 1
  discover_spatial_order

  local seen_accordion=false wid
  for wid in "${_spatial[@]}"; do
    if echo "$accordion_ids" | grep -qx "$wid"; then
      seen_accordion=true
    elif echo "$sidebar_ids" | grep -qx "$wid" && $seen_accordion; then
      return 1
    fi
  done
  return 0
}

layout_already_correct() {
  local ws="$1" sidebar_ids="$2" accordion_ids="$3"

  layout_tree_correct "$ws" "$sidebar_ids" "$accordion_ids" &&
    layout_order_correct "$ws" "$sidebar_ids" "$accordion_ids"
}

# Walk left-to-right from the currently focused window to discover
# the full spatial order. Results stored in global _spatial array.
#
# Two terminator conditions, both needed:
#   1. n == p — focus held at boundary (works when --boundaries-action stop
#      engages cleanly).
#   2. n already seen — focus cycled back. AeroSpace's `stop` action does
#      not always engage if a phantom/unfocusable window survived the
#      sweep_unfocusable pass. Cycle detection is the final backstop.
discover_spatial_order() {
  _spatial=()
  local p n seen
  # Walk to leftmost
  while true; do
    p=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    aerospace focus --boundaries-action stop left 2>/dev/null
    n=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    [[ "$n" == "$p" ]] && break
  done
  _spatial+=("$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)")
  # Walk right collecting; break on stop OR cycle
  while true; do
    p=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    aerospace focus --boundaries-action stop right 2>/dev/null
    n=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    [[ "$n" == "$p" ]] && break
    seen=false
    for w in "${_spatial[@]}"; do
      [[ "$w" == "$n" ]] && { seen=true; break; }
    done
    $seen && break
    _spatial+=("$n")
  done
}

arrange_workspace_once() {
  local ws="$1"

  local windows
  windows=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null) || return 0
  local total
  total=$(echo "$windows" | jq 'length')

  [[ "$total" -lt 2 ]] && return 0

  # Skip if the window set hasn't changed since last arrangement.
  # The fingerprint covers window IDs + app names; if nothing changed
  # there can't be a new phantom either, so we can skip the sweep too.
  local fingerprint marker_file
  fingerprint=$(workspace_fingerprint "$windows")
  marker_file="$MARKER_DIR/ws-$ws"
  if [[ "$FORCE" != true ]] && [[ -f "$marker_file" ]] && [[ "$(cat "$marker_file")" == "$fingerprint" ]]; then
    echo "  [$ws] already arranged, skipping"
    return 0
  fi

  # Sweep phantom/unfocusable windows to Z before computing the layout.
  # These break spatial navigation, join-with, and move commands. If any
  # were swept, re-read the window list, re-check the early-exit, and
  # re-compute the fingerprint (it's what we'll write to the marker).
  local swept
  swept=$(sweep_unfocusable "$ws" "$windows")
  if [[ "$swept" -gt 0 ]]; then
    windows=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null) || return 0
    total=$(echo "$windows" | jq 'length')
    [[ "$total" -lt 2 ]] && return 0
    fingerprint=$(workspace_fingerprint "$windows")
  fi

  local sidebar_ids accordion_ids
  sidebar_ids=$(echo "$windows" | jq -r \
    --arg pat "$SIDEBAR_TITLE_PATTERN" \
    '[.[] | select(.["window-title"] | test($pat))] | .[]["window-id"]') || true
  accordion_ids=$(echo "$windows" | jq -r \
    --arg pat "$SIDEBAR_TITLE_PATTERN" \
    '[.[] | select(.["window-title"] | test($pat) | not)] | .[]["window-id"]') || true

  local accordion_count=0 sidebar_count=0
  [[ -n "$accordion_ids" ]] && accordion_count=$(echo "$accordion_ids" | wc -l | tr -d ' ')
  [[ -n "$sidebar_ids" ]] && sidebar_count=$(echo "$sidebar_ids" | wc -l | tr -d ' ')

  # Only accordion windows → flat accordion, no nesting needed
  if [[ "$sidebar_count" -eq 0 ]]; then
    if layout_already_correct "$ws" "" "$accordion_ids"; then
      echo "  [$ws] flat accordion already correct → marker only"
      echo "$fingerprint" > "$marker_file"
      return 0
    fi
    echo "  [$ws] ${accordion_count} accordion window(s), no sidebar → flat accordion"
    aerospace workspace "$ws" 2>/dev/null
    aerospace flatten-workspace-tree 2>/dev/null || true
    aerospace layout accordion vertical 2>/dev/null || true
    if layout_already_correct "$ws" "" "$accordion_ids"; then
      echo "$fingerprint" > "$marker_file"
      return 0
    fi
    echo "  [$ws] flat accordion verification failed" >&2
    return 1
  fi

  # No accordion windows → leave as-is
  if [[ "$accordion_count" -eq 0 ]]; then
    echo "  [$ws] no non-Orchest windows, skipping"
    return 0
  fi

  if layout_already_correct "$ws" "$sidebar_ids" "$accordion_ids"; then
    echo "  [$ws] sidebar+accordion already correct → enforcing split + marker"
    enforce_split "$(echo "$accordion_ids" | head -1)"
    echo "$fingerprint" > "$marker_file"
    return 0
  fi

  echo "  [$ws] ${sidebar_count} sidebar + ${accordion_count} accordion → tiles | accordion"
  echo "    sidebar_ids: $(echo $sidebar_ids | tr '\n' ' ')"
  echo "    accordion_ids: $(echo $accordion_ids | tr '\n' ' ')"

  aerospace workspace "$ws" 2>/dev/null

  # Unfloat any floating windows so they participate in the tiling tree
  local all_ids
  all_ids=$(echo "$windows" | jq -r '.[]["window-id"]')
  for wid in $all_ids; do
    local parent_layout
    parent_layout=$(aerospace list-windows --all --format '%{window-id}|%{window-parent-container-layout}' 2>/dev/null \
      | grep "^${wid}|" | cut -d'|' -f2)
    if [[ "$parent_layout" == "floating" ]]; then
      echo "    unfloating window $wid"
      aerospace focus --window-id "$wid" 2>/dev/null
      aerospace layout tiling 2>/dev/null || true
    fi
  done

  aerospace flatten-workspace-tree 2>/dev/null || true

  echo "    after flatten: $(aerospace list-windows --workspace "$ws" --format '%{window-id}:%{window-parent-container-layout}' 2>/dev/null | tr '\n' ' ')"

  # Root defaults to accordion after flatten (default-root-container-layout).
  # Set to tiles horizontal immediately so move/join commands behave correctly.
  local first_sidebar
  first_sidebar=$(echo "$sidebar_ids" | head -1)
  aerospace focus --window-id "$first_sidebar" 2>/dev/null
  # Use h_tiles directly — `layout tiles horizontal` cycles through args
  # rather than setting both, so it leaves a v_accordion root as v_tiles.
  aerospace layout h_tiles 2>/dev/null || true

  echo "    after h_tiles: $(aerospace list-windows --workspace "$ws" --format '%{window-id}:%{window-parent-container-layout}' 2>/dev/null | tr '\n' ' ')"

  # Sort windows so all sidebar windows are on the left and all accordion
  # windows are on the right. Swaps accordion windows rightward past sidebar
  # windows — an interior swap between flat root-level siblings.
  # Multiple passes handle cascading cases (e.g. [acc, acc, sidebar]).
  #
  # Capped at sidebar_count * accordion_count (bubble-sort worst case) so
  # a silently-no-op'd `move right` can't infinite-loop the script.
  local swap_max=$(( sidebar_count * accordion_count ))
  local swap_iter=0
  local swap_overflow=false
  while true; do
    aerospace focus --window-id "$first_sidebar" 2>/dev/null
    discover_spatial_order
    echo "    swap scan: ${_spatial[*]}"

    local did_swap=false
    for ((idx = 0; idx < ${#_spatial[@]} - 1; idx++)); do
      local cur="${_spatial[$idx]}" nxt="${_spatial[$((idx + 1))]}"
      if echo "$accordion_ids" | grep -qx "$cur" && \
         echo "$sidebar_ids" | grep -qx "$nxt"; then
        if [[ "$swap_iter" -ge "$swap_max" ]]; then
          swap_overflow=true
          break
        fi
        swap_iter=$(( swap_iter + 1 ))
        echo "    swapping $cur right (past sidebar $nxt)"
        aerospace focus --window-id "$cur" 2>/dev/null
        aerospace move right 2>/dev/null || true
        did_swap=true
        break
      fi
    done
    $swap_overflow && break
    $did_swap || break
  done
  if $swap_overflow; then
    echo "  [$ws] swap budget ($swap_max) exhausted — bailing without marker so next pass retries"
    return 1
  fi

  # Final spatial discovery after sorting
  aerospace focus --window-id "$first_sidebar" 2>/dev/null
  discover_spatial_order
  echo "    final spatial: ${_spatial[*]}"

  local spatial_accordion=()
  for wid in "${_spatial[@]}"; do
    if ! echo "$sidebar_ids" | grep -qx "$wid"; then
      spatial_accordion+=("$wid")
    fi
  done
  local spatial_count=${#spatial_accordion[@]}
  # `${arr[*]}` on an empty array trips `set -u` in bash 3.2.
  echo "    spatial_accordion: ${spatial_accordion[*]:-} (count=$spatial_count)"

  # Build the accordion group.
  local first_accordion
  first_accordion=$(echo "$accordion_ids" | head -1)

  if [[ "$spatial_count" -gt 1 ]]; then
    local rightmost="${spatial_accordion[$((spatial_count - 1))]}"

    echo "    join-with: focusing $rightmost, join-with left"
    # Create initial 2-child container from the rightmost pair
    aerospace focus --window-id "$rightmost" 2>/dev/null
    aerospace join-with left 2>/dev/null || true

    echo "    after join-with: $(aerospace list-windows --workspace "$ws" --format '%{window-id}:%{window-parent-container-layout}' 2>/dev/null | tr '\n' ' ')"

    # Verify join-with actually nested $rightmost. join-with-left silently
    # no-ops when the left neighbor isn't a joinable tiling sibling
    # (mid-creation, just-unfloated, etc.). After a successful join from
    # h_tiles root the parent is a perpendicular v_tiles sub-container; if
    # parent is still h_tiles we'd be calling `layout accordion` on a
    # root-level child and flipping ROOT to accordion (see gotcha above).
    # Bail without writing the marker so the next pass retries.
    local parent_layout
    parent_layout=$(aerospace list-windows --focused \
      --format '%{window-parent-container-layout}' 2>/dev/null)
    if [[ "$parent_layout" == "h_tiles" ]]; then
      echo "  [$ws] join-with no-op'd (parent still h_tiles); bailing before accordion to avoid root corruption"
      return 1
    fi

    # Set it to accordion
    aerospace layout accordion 2>/dev/null || true

    echo "    after layout accordion: $(aerospace list-windows --workspace "$ws" --format '%{window-id}:%{window-parent-container-layout}' 2>/dev/null | tr '\n' ' ')"

    # Move preceding windows into the accordion (right-to-left)
    for (( i = spatial_count - 3; i >= 0; i-- )); do
      aerospace focus --window-id "${spatial_accordion[$i]}" 2>/dev/null || continue
      aerospace move right 2>/dev/null || true
    done
  elif [[ "$spatial_count" -eq 1 ]]; then
    # Single accordion window — create a single-child accordion container
    # using a scaffold window. We can't join the accordion with the sidebar
    # because extracting the sidebar afterward always lands it rightmost,
    # and `move left` enters the accordion rather than swapping.
    # Instead: borrow a window from Z, join it with the accordion window
    # (scaffold lands rightmost, so join-with left pairs them), set to
    # accordion, then return the scaffold. The sidebar never moves.
    local scaffold_wid
    scaffold_wid=$(aerospace list-windows --workspace Z \
      --format '%{window-id}|%{window-parent-container-layout}' 2>/dev/null \
      | grep -v '|floating$' | head -1 | cut -d'|' -f1)

    if [[ -n "$scaffold_wid" ]]; then
      echo "    scaffold: borrowing $scaffold_wid from Z"
      aerospace move-node-to-workspace --window-id "$scaffold_wid" "$ws" 2>/dev/null || true

      # Scaffold lands rightmost: [..., accordion, scaffold]
      aerospace focus --window-id "$scaffold_wid" 2>/dev/null
      aerospace join-with left 2>/dev/null || true

      # Verify the scaffold actually joined. If parent is still h_tiles,
      # join-with no-op'd (target window in transient state) — calling
      # `layout accordion` here would flip ROOT to accordion. Return the
      # scaffold and bail without the marker so the next pass retries.
      local scaffold_parent
      scaffold_parent=$(aerospace list-windows --focused \
        --format '%{window-parent-container-layout}' 2>/dev/null)
      if [[ "$scaffold_parent" == "h_tiles" ]]; then
        echo "  [$ws] scaffold join-with no-op'd; returning scaffold and bailing"
        aerospace move-node-to-workspace --window-id "$scaffold_wid" Z 2>/dev/null || true
        return 1
      fi

      aerospace layout accordion 2>/dev/null || true

      # Return scaffold — single-child accordion persists
      aerospace move-node-to-workspace --window-id "$scaffold_wid" Z 2>/dev/null || true
    else
      echo "    no scaffold window on Z, skipping single-child accordion"
      return 1
    fi
  fi

  # Group sidebar windows so root has exactly 2 children → even split
  if [[ "$sidebar_count" -gt 1 ]]; then
    aerospace focus --window-id "$first_sidebar" 2>/dev/null
    for _ in $(seq 1 $((sidebar_count - 1))); do
      aerospace join-with right 2>/dev/null || true
    done
    # Set sidebar container to horizontal tiles
    aerospace layout h_tiles 2>/dev/null || true
  fi

  # Set the sidebar/accordion split for the current monitor.
  enforce_split "$first_accordion"

  if layout_already_correct "$ws" "$sidebar_ids" "$accordion_ids"; then
    echo "$fingerprint" > "$marker_file"
    return 0
  fi

  echo "  [$ws] layout verification failed" >&2
  return 1
}

arrange_workspace() {
  local ws="$1"
  local attempt=1

  while [[ "$attempt" -le "$ARRANGE_ATTEMPTS" ]]; do
    if arrange_workspace_once "$ws"; then
      return 0
    fi

    if [[ "$attempt" -lt "$ARRANGE_ATTEMPTS" ]]; then
      echo "  [$ws] arrangement incomplete; retrying in ${ARRANGE_RETRY_SLEEP}s (${attempt}/${ARRANGE_ATTEMPTS})" >&2
      sleep "$ARRANGE_RETRY_SLEEP"
    fi
    attempt=$(( attempt + 1 ))
  done

  echo "  [$ws] ERROR: arrangement did not converge after ${ARRANGE_ATTEMPTS} attempt(s)" >&2
  return 1
}

# ── Main ──────────────────────────────────────────────────────────────

# Accept workspace list as args, or default to all non-empty workspaces
if [[ $# -gt 0 ]]; then
  workspaces=("$@")
else
  while IFS= read -r w; do
    workspaces+=("$w")
  done < <(
    aerospace list-workspaces --all --json 2>/dev/null \
      | jq -r '.[]["workspace"]'
  )
fi

echo "Arranging workspace layouts..."
failures=0
for ws in "${workspaces[@]}"; do
  if ! arrange_workspace "$ws"; then
    failures=$(( failures + 1 ))
  fi
done
if [[ "$failures" -gt 0 ]]; then
  echo "Done with ${failures} workspace arrangement failure(s)." >&2
  exit 1
fi
echo "Done."
