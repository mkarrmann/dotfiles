#!/usr/bin/env bash
set -euo pipefail

# arrange-workspaces: On each workspace, put Orchest windows as tiles on the
# left (sidebar) and all other windows in an accordion on the right.
# If a workspace has no Orchest windows, it stays as a flat accordion.
# Skips workspaces whose window set hasn't changed since last arrangement
# to preserve manual size adjustments. Use --force to override.
# Can be run standalone or called from startup-windows.
#
# AeroSpace gotchas this script works around:
#   - default-root-container-layout is 'accordion', so flatten-workspace-tree
#     resets root to accordion. We immediately override with tiles horizontal.
#   - `move left/right` at a container boundary creates UNINTENDED nesting
#     (e.g. v_tiles sub-container) instead of stopping. Never use `move` to
#     push a window past the edge — only use it for interior swaps.
#   - `layout accordion` on a direct child of root changes the ROOT layout,
#     not the child's. Only use it on windows inside a nested container
#     (created by join-with).
#   - Spatial order after flatten is unpredictable — Orchest (added last by
#     orchest-open-workspaces) often ends up rightmost. Discover order by
#     walking focus left-to-right; don't assume sidebar is leftmost.
#
# Debugging: check layout state with:
#   aerospace list-windows --workspace N --format \
#     '%{window-id} %{app-name} | parent=%{window-parent-container-layout} | root=%{workspace-root-container-layout}'

SIDEBAR_TITLE_PATTERN="Orchest \\["
SIDEBAR_PERCENT=20
MARKER_DIR="/tmp/aerospace-arrange-markers"
FORCE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force|-f) FORCE=true; shift ;;
    *) break ;;
  esac
done

mkdir -p "$MARKER_DIR"

get_screen_width() {
  osascript -l JavaScript -e \
    'ObjC.import("AppKit"); $.NSScreen.mainScreen.frame.size.width' 2>/dev/null || echo 0
}

workspace_fingerprint() {
  local windows="$1"
  echo "$windows" | jq -r '.[] | "\(.["window-id"]):\(.["app-name"])"' | sort | md5 -q
}

arrange_workspace() {
  local ws="$1"

  local windows
  windows=$(aerospace list-windows --workspace "$ws" --json 2>/dev/null) || return 0
  local total
  total=$(echo "$windows" | jq 'length')

  [[ "$total" -lt 2 ]] && return 0

  # Skip if the window set hasn't changed since last arrangement
  local fingerprint marker_file
  fingerprint=$(workspace_fingerprint "$windows")
  marker_file="$MARKER_DIR/ws-$ws"
  if [[ "$FORCE" != true ]] && [[ -f "$marker_file" ]] && [[ "$(cat "$marker_file")" == "$fingerprint" ]]; then
    echo "  [$ws] already arranged, skipping"
    return 0
  fi

  local sidebar_ids accordion_ids
  sidebar_ids=$(echo "$windows" | jq -r \
    --arg pat "$SIDEBAR_TITLE_PATTERN" \
    '[.[] | select(.["window-title"] | test($pat))] | .[]["window-id"]') || true
  accordion_ids=$(echo "$windows" | jq -r \
    --arg pat "$SIDEBAR_TITLE_PATTERN" \
    '[.[] | select(.["window-title"] | test($pat) | not)] | .[]["window-id"]') || true

  local accordion_count=0 sidebar_count=0
  [[ -n "$accordion_ids" ]] && accordion_count=$(echo "$accordion_ids" | wc -l | tr -d ' ')
  [[ -n "$sidebar_ids" ]] && sidebar_count=$(echo "$sidebar_ids" | wc -l | tr -d ' ')

  # Only accordion windows → flat accordion, no nesting needed
  if [[ "$sidebar_count" -eq 0 ]]; then
    echo "  [$ws] ${accordion_count} accordion window(s), no sidebar → flat accordion"
    aerospace workspace "$ws" 2>/dev/null
    aerospace flatten-workspace-tree 2>/dev/null || true
    aerospace layout accordion vertical 2>/dev/null || true
    echo "$fingerprint" > "$marker_file"
    return 0
  fi

  # No accordion windows → leave as-is
  if [[ "$accordion_count" -eq 0 ]]; then
    echo "  [$ws] no non-Orchest windows, skipping"
    return 0
  fi

  echo "  [$ws] ${sidebar_count} sidebar + ${accordion_count} accordion → tiles | accordion"

  aerospace workspace "$ws" 2>/dev/null
  aerospace flatten-workspace-tree 2>/dev/null || true

  # Root defaults to accordion after flatten (default-root-container-layout).
  # Set to tiles horizontal immediately so move/join commands behave correctly.
  local first_sidebar
  first_sidebar=$(echo "$sidebar_ids" | head -1)
  aerospace focus --window-id "$first_sidebar" 2>/dev/null
  aerospace layout tiles horizontal 2>/dev/null || true

  # Discover full spatial order by walking from the left edge.
  # Avoid using `move` to reposition — it can create unintended nesting
  # at container boundaries.
  aerospace focus --window-id "$first_sidebar" 2>/dev/null
  while true; do
    local p; p=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    aerospace focus left 2>/dev/null
    local n; n=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    [[ "$n" == "$p" ]] && break
  done

  local all_spatial=()
  all_spatial+=($(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null))
  while true; do
    local p; p=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    aerospace focus right 2>/dev/null
    local n; n=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
    [[ "$n" == "$p" ]] && break
    all_spatial+=("$n")
  done

  # Build a set of sidebar IDs and extract accordion windows in spatial order
  local spatial_accordion=()
  for wid in "${all_spatial[@]}"; do
    if ! echo "$sidebar_ids" | grep -qx "$wid"; then
      spatial_accordion+=("$wid")
    fi
  done
  local spatial_count=${#spatial_accordion[@]}

  # If accordion windows aren't adjacent (sidebar between them), do a safe
  # interior swap: move the left-side accordion window right to push past
  # the sidebar.  This avoids boundary moves that create nesting.
  if [[ "$spatial_count" -ge 2 ]]; then
    local need_swap=false
    for ((idx = 0; idx < ${#all_spatial[@]} - 1; idx++)); do
      local cur="${all_spatial[$idx]}" nxt="${all_spatial[$((idx + 1))]}"
      # Accordion window followed by sidebar → they're not adjacent
      if [[ -n "$(echo "$accordion_ids" | grep "^${cur}$")" ]] && \
         [[ -n "$(echo "$sidebar_ids" | grep "^${nxt}$")" ]]; then
        aerospace focus --window-id "$cur" 2>/dev/null
        aerospace move right 2>/dev/null || true
        need_swap=true
      fi
    done
    if $need_swap; then
      # Re-flatten to clean up any side effects, re-discover order
      aerospace flatten-workspace-tree 2>/dev/null || true
      aerospace focus --window-id "$first_sidebar" 2>/dev/null
      aerospace layout tiles horizontal 2>/dev/null || true
      spatial_accordion=()
      aerospace focus --window-id "$first_sidebar" 2>/dev/null
      while true; do
        local p; p=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
        aerospace focus right 2>/dev/null
        local n; n=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null)
        [[ "$n" == "$p" ]] && break
        spatial_accordion+=("$n")
      done
      spatial_count=${#spatial_accordion[@]}
    fi
  fi

  # Build the accordion group.
  #
  # Goal: all accordion windows inside a nested accordion container so that
  # auto-accordion's `move right` has a container to enter when the user
  # later opens new windows manually.
  #
  # For 2+ windows: focus the rightmost, join-with left → creates a 2-child
  #   container, set it to accordion, then move preceding windows in.
  # For 1 window: `split vertical` wraps it in its own sub-container, then
  #   set that to accordion.  Without the split, `layout accordion` would
  #   target the ROOT (the parent of a root-level child), breaking the
  #   sidebar | accordion split.
  local first_accordion
  first_accordion=$(echo "$accordion_ids" | head -1)

  if [[ "$spatial_count" -gt 1 ]]; then
    local rightmost="${spatial_accordion[$((spatial_count - 1))]}"

    # Create initial 2-child container from the rightmost pair
    aerospace focus --window-id "$rightmost" 2>/dev/null
    aerospace join-with left 2>/dev/null || true

    # Set it to accordion
    aerospace layout accordion 2>/dev/null || true

    # Move preceding windows into the accordion (right-to-left)
    for (( i = spatial_count - 3; i >= 0; i-- )); do
      aerospace focus --window-id "${spatial_accordion[$i]}" 2>/dev/null || continue
      aerospace move right 2>/dev/null || true
    done
  elif [[ "$spatial_count" -eq 1 ]]; then
    # Single accordion window — can't create a nested container because
    # AeroSpace auto-collapses single-child containers. Leave it as a
    # direct child of root (flat tiles split with sidebar). When a second
    # window arrives, auto-accordion detects the missing container and
    # calls arrange-workspaces to build it.
    :
  fi

  # Group sidebar windows so root has exactly 2 children → even split
  if [[ "$sidebar_count" -gt 1 ]]; then
    aerospace focus --window-id "$first_sidebar" 2>/dev/null
    for _ in $(seq 1 $((sidebar_count - 1))); do
      aerospace join-with right 2>/dev/null || true
    done
    # Set sidebar container to horizontal tiles
    aerospace layout tiles horizontal 2>/dev/null || true
  fi

  # Resize from the default 50/50 to the configured split.
  # Focusing the accordion window propagates the width resize up through
  # the accordion container (which doesn't split horizontally) to root.
  local accordion_percent=$((100 - SIDEBAR_PERCENT))
  if [[ "$accordion_percent" -ne 50 ]]; then
    local screen_width
    screen_width=$(get_screen_width)
    if [[ "$screen_width" -gt 0 ]]; then
      local delta=$(( screen_width * (accordion_percent - 50) / 100 ))
      aerospace focus --window-id "$first_accordion" 2>/dev/null
      aerospace resize width "+$delta" 2>/dev/null || true
    fi
  fi

  echo "$fingerprint" > "$marker_file"
}

# ── Main ──────────────────────────────────────────────────────────────

# Accept workspace list as args, or default to all non-empty workspaces
if [[ $# -gt 0 ]]; then
  workspaces=("$@")
else
  while IFS= read -r w; do
    workspaces+=("$w")
  done < <(
    aerospace list-workspaces --all --json 2>/dev/null \
      | jq -r '.[]["workspace"]'
  )
fi

echo "Arranging workspace layouts..."
for ws in "${workspaces[@]}"; do
  arrange_workspace "$ws"
done
echo "Done."
