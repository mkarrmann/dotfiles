#!/bin/bash
set -uo pipefail

# arrange-ws11: build the workspace 11 "dashboard" and pin it to the external
# secondary monitor.
#
#   ┌──────────────┬──────────────────────┐
#   │ Calendar 27% │ Obsidian         73% │   top row (internalfb calendar)
#   ├──────────────┴──────────────────────┤
#   │ Chat 70%              │ Orchest  30% │   bottom row (Google Chat / Orchest)
#   └──────────────────────┴──────────────┘
#
# Rows are 50/50 height; per-row width splits are TOP_LEFT_PCT / BOT_LEFT_PCT.
#
# Design notes / AeroSpace gotchas this script relies on:
#   - Directional `focus`/`join` are SPATIAL and cross monitors unpredictably
#     when the workspace lives on a side monitor. We therefore never navigate by
#     direction: window→cell placement is made deterministic by emptying the
#     workspace and re-inserting the four windows in a fixed order, then joining
#     pairs by known window-id (join-with pairs the focused window with its
#     in-column neighbour; the focused window becomes the left cell).
#   - `flatten-workspace-tree` only acts on the focused workspace and can no-op
#     if called immediately after a move; we focus a ws-11 window by id first and
#     retry until the tree is flat.
#   - `enable-normalization-opposite-orientation-for-nested-containers = true`
#     turns each join under the v_tiles root into a perpendicular h_tiles row —
#     which is exactly the grid we want, and it is normalization-stable.
#   - Resize needs the target monitor's width. We read it from AppKit NSScreen
#     (no Accessibility permission required), matching AeroSpace's
#     monitor-appkit-nsscreen-screens-id (a 1-based index into NSScreen.screens).
#
# Idempotent. Safe to run standalone or from startup-windows.

AEROSPACE_COMMAND_TIMEOUT="${AEROSPACE_COMMAND_TIMEOUT:-8}"
AEROSPACE_TIMEOUT_BIN="$(command -v timeout || command -v gtimeout || true)"
AEROSPACE_BIN="$(command -v aerospace || true)"

aerospace() {
  local attempts=1 attempt=1 output status
  case "${1:-}" in
    list-*) attempts=3 ;;
  esac
  while [[ "$attempt" -le "$attempts" ]]; do
    if [[ -n "$AEROSPACE_TIMEOUT_BIN" ]]; then
      if output=$("$AEROSPACE_TIMEOUT_BIN" --foreground --kill-after=1 \
          "$AEROSPACE_COMMAND_TIMEOUT" "$AEROSPACE_BIN" "$@"); then
        printf '%s' "$output"; return 0
      else status=$?; fi
    else
      if output=$("$AEROSPACE_BIN" "$@"); then printf '%s' "$output"; return 0; else status=$?; fi
    fi
    if [[ "$status" -eq 124 || "$status" -eq 137 ]]; then
      echo "WARNING: AeroSpace command timed out: aerospace $*" >&2
    fi
    attempt=$(( attempt + 1 ))
    [[ "$attempt" -le "$attempts" ]] && sleep 0.25
  done
  return "$status"
}

# ── Config ───────────────────────────────────────────────────────────
WS=11
SWEEP_WORKSPACE="Z"
LAPTOP_RE='Built-in|Retina'
TOP_LEFT_PCT=27   # Calendar's width share of the top row
BOT_LEFT_PCT=70   # Chat's width share of the bottom row
CHROME_APP="Google Chrome"
CAL_URL="https://www.internalfb.com/calendar"
CHAT_URL="https://chat.google.com/u/0/app/home"
# Identity matchers: app name + window-title regex. Order = TL, TR, BL, BR.
CAL_TITLE_RE='^Calendar\b'
CHAT_TITLE_RE='^Chat\b'
ORCHEST_TITLE_RE='^Orchest$'
ATTEMPTS="${WS11_ATTEMPTS:-4}"

if [[ -z "$AEROSPACE_BIN" ]]; then echo "ERROR: aerospace CLI not found." >&2; exit 1; fi
if ! aerospace list-windows --all &>/dev/null; then echo "ERROR: AeroSpace is not running." >&2; exit 1; fi

# ── Helpers ──────────────────────────────────────────────────────────

# find_id APP TITLE_RE -> first matching window id anywhere (or empty)
find_id() {
  aerospace list-windows --all --json 2>/dev/null | jq -r \
    --arg app "$1" --arg re "$2" \
    '[.[] | select(."app-name"==$app and ((.["window-title"]//"")|test($re)))]
       | first | .["window-id"] // empty'
}

snapshot() { aerospace list-windows --all --json 2>/dev/null; }

# wait for a new window of APP to appear relative to BEFORE_JSON; echo its id
wait_for_new_window() {
  local app="$1" before="$2" before_ids
  before_ids=$(echo "$before" | jq -r --arg a "$app" '[.[]|select(."app-name"==$a)]|.[]["window-id"]' | sort -n)
  local _ cur new
  for _ in $(seq 1 30); do
    sleep 0.5
    cur=$(snapshot | jq -r --arg a "$app" '[.[]|select(."app-name"==$a)]|.[]["window-id"]' | sort -n)
    new=$(comm -23 <(echo "$cur") <(echo "$before_ids") | head -1)
    [[ -n "$new" ]] && { echo "$new"; return 0; }
  done
  return 1
}

open_chrome_url() {
  local url="$1" before wid
  before=$(snapshot)
  open -na "$CHROME_APP" --args --profile-directory=Default --new-window "$url" 2>/dev/null || return 1
  wid=$(wait_for_new_window "$CHROME_APP" "$before") || return 1
  echo "$wid"
}

# ensure_chrome TITLE_RE URL -> echo window id (reuse existing or open URL)
ensure_chrome() {
  local re="$1" url="$2" wid
  wid=$(find_id "$CHROME_APP" "$re")
  if [[ -z "$wid" ]]; then
    echo "[ws11] opening Chrome $url" >&2
    wid=$(open_chrome_url "$url") || return 1
    # give the tab a moment to load its title so later runs can match it
    sleep 1
  fi
  echo "$wid"
}

# ensure_app APP_BUNDLE_OR_NAME TITLE_RE -> echo window id (launch if missing)
ensure_app_window() {
  local app="$1" re="$2" wid before
  wid=$(find_id "$app" "$re")
  if [[ -z "$wid" ]]; then
    echo "[ws11] launching $app" >&2
    before=$(snapshot)
    open -a "$app" 2>/dev/null || true
    wid=$(wait_for_new_window "$app" "$before") || wid=$(find_id "$app" "$re")
  fi
  echo "$wid"
}

# NSScreen width (points) for AeroSpace target monitor id; 0 if unknown
monitor_width() {
  local mid="$1" nsid
  nsid=$(aerospace list-monitors --format '%{monitor-id}|%{monitor-appkit-nsscreen-screens-id}' 2>/dev/null \
    | awk -F'|' -v m="$mid" '$1==m{print $2; exit}')
  [[ -z "$nsid" ]] && { echo 0; return; }
  osascript -l JavaScript -e "ObjC.import('AppKit');(function(){var s=\$.NSScreen.screens;var i=${nsid}-1;if(i<0||i>=s.count)return 0;return Math.round(s.objectAtIndex(i).frame.size.width);})()" 2>/dev/null || echo 0
}

# target monitor id: external (non-main, non-laptop) > any non-main > main
select_target_monitor() {
  local lines id name ismain main_id="" ext_id="" other_id=""
  lines=$(aerospace list-monitors --format '%{monitor-id}|%{monitor-name}|%{monitor-is-main}' 2>/dev/null)
  while IFS='|' read -r id name ismain; do
    [[ -z "$id" ]] && continue
    if [[ "$ismain" == "true" ]]; then main_id="$id"; continue; fi
    if echo "$name" | grep -qE "$LAPTOP_RE"; then
      [[ -z "$other_id" ]] && other_id="$id"
    else
      [[ -z "$ext_id" ]] && ext_id="$id"
    fi
  done <<< "$lines"
  if   [[ -n "$ext_id"   ]]; then echo "$ext_id"
  elif [[ -n "$other_id" ]]; then echo "$other_id"
  else echo "$main_id"; fi
}

# focus a ws-11 window by id, flatten, retry until the tree is a flat v_tiles column
flatten_flat() {
  local anchor="$1" attempt nonflat root
  for attempt in 1 2 3 4 5 6; do
    aerospace focus --window-id "$anchor" 2>/dev/null; sleep 0.15
    aerospace flatten-workspace-tree 2>/dev/null || true; sleep 0.35
    root=$(aerospace list-windows --workspace "$WS" --format '%{workspace-root-container-layout}' | head -1)
    if [[ "$root" != "v_tiles" ]]; then
      aerospace focus --window-id "$anchor" 2>/dev/null
      aerospace layout v_tiles 2>/dev/null || true; sleep 0.2
    fi
    nonflat=$(aerospace list-windows --workspace "$WS" \
      --format '%{window-parent-container-layout}:%{workspace-root-container-layout}' \
      | awk -F: '$1!=$2{c++} END{print c+0}')
    [[ "$nonflat" -eq 0 ]] && return 0
  done
  return 1
}

# ── Resolve the four windows ─────────────────────────────────────────
# Retry title-based resolution first: window titles can be briefly empty
# right after windows appear (and AeroSpace/AX titles occasionally lag).
# Only open/launch as a last resort, so a transient blank title never
# causes a duplicate window to be spawned.
echo "arrange-ws11: resolving windows..."
CAL=""; OBS=""; CHAT=""; ORCH=""
for _ in $(seq 1 8); do
  [[ -z "$CAL"  ]] && CAL=$(find_id "$CHROME_APP" "$CAL_TITLE_RE")
  [[ -z "$CHAT" ]] && CHAT=$(find_id "$CHROME_APP" "$CHAT_TITLE_RE")
  [[ -z "$OBS"  ]] && OBS=$(find_id "Obsidian" '.')
  [[ -z "$ORCH" ]] && ORCH=$(find_id "Orchest" "$ORCHEST_TITLE_RE")
  [[ -n "$CAL" && -n "$CHAT" && -n "$OBS" && -n "$ORCH" ]] && break
  sleep 1
done
[[ -z "$CAL"  ]] && CAL=$(ensure_chrome "$CAL_TITLE_RE" "$CAL_URL")
[[ -z "$CHAT" ]] && CHAT=$(ensure_chrome "$CHAT_TITLE_RE" "$CHAT_URL")
[[ -z "$OBS"  ]] && OBS=$(ensure_app_window "Obsidian" '.')
[[ -z "$ORCH" ]] && ORCH=$(ensure_app_window "Orchest" "$ORCHEST_TITLE_RE")
echo "  cal(TL)=$CAL obs(TR)=$OBS chat(BL)=$CHAT orch(BR)=$ORCH"

missing=0
for pair in "Calendar $CAL" "Obsidian $OBS" "Chat $CHAT" "Orchest $ORCH"; do
  set -- $pair
  [[ -z "${2:-}" ]] && { echo "WARNING: [ws11] $1 window not found" >&2; missing=1; }
done

# ── Place ws 11 on the external secondary monitor ────────────────────
TARGET_MON=$(select_target_monitor)
if [[ -n "$TARGET_MON" ]]; then
  echo "arrange-ws11: pinning workspace $WS to monitor $TARGET_MON"
  aerospace move-workspace-to-monitor --workspace "$WS" "$TARGET_MON" 2>/dev/null || true
fi

if [[ "$missing" -ne 0 ]]; then
  echo "arrange-ws11: some windows missing; moving what exists to ws $WS and skipping grid" >&2
  for wid in "$CAL" "$OBS" "$CHAT" "$ORCH"; do
    [[ -n "$wid" ]] && aerospace move-node-to-workspace --window-id "$wid" "$WS" 2>/dev/null || true
  done
  exit 1
fi

# ── Build the 2×2 (deterministic; verify by geometry when available) ──
build_grid() {
  # 1. empty ws 11, then re-insert in a fixed order -> deterministic column
  local wid
  for wid in "$CAL" "$OBS" "$CHAT" "$ORCH"; do
    aerospace move-node-to-workspace --window-id "$wid" "$SWEEP_WORKSPACE" 2>/dev/null || true
  done
  sleep 0.3
  for wid in "$CAL" "$OBS" "$CHAT" "$ORCH"; do
    aerospace move-node-to-workspace --window-id "$wid" "$WS" 2>/dev/null || true; sleep 0.15
  done
  sleep 0.2
  # 2. flatten to a v_tiles column [CAL, OBS, CHAT, ORCH] top->bottom
  flatten_flat "$CAL" || { echo "  flatten did not converge" >&2; return 1; }
  # 3. join top pair, then bottom pair (focused window becomes the left cell)
  aerospace focus --window-id "$CAL" 2>/dev/null; aerospace join-with down 2>/dev/null || true; sleep 0.3
  aerospace focus --window-id "$CHAT" 2>/dev/null; aerospace join-with down 2>/dev/null || true; sleep 0.3
  # all four should now be under h_tiles rows
  local nonrow
  nonrow=$(aerospace list-windows --workspace "$WS" --format '%{window-parent-container-layout}' \
    | awk '$0!="h_tiles"{c++} END{print c+0}')
  [[ "$nonrow" -eq 0 ]]
}

# System Events geometry cache: "title\tx\ty\tw\th" (best-effort; may be empty)
GEOM=""
refresh_geom() {
  GEOM=$(osascript <<'OSA' 2>/dev/null
set out to ""
repeat with appName in {"Google Chrome", "Obsidian", "Orchest"}
  try
    tell application "System Events" to tell process (appName as string)
      repeat with w in windows
        set p to position of w
        set s to size of w
        set out to out & (name of w) & "\t" & (item 1 of p) & "\t" & (item 2 of p) & "\t" & (item 1 of s) & "\t" & (item 2 of s) & linefeed
      end repeat
    end tell
  end try
end repeat
return out
OSA
)
}
title_of() { aerospace list-windows --workspace "$WS" --format '%{window-id}|%{window-title}' | awk -F'|' -v w="$1" '$1==w{print $2}'; }
# frame_of ID -> "x y w h" (empty if geometry unavailable)
frame_of() { local t; t=$(title_of "$1"); awk -F'\t' -v t="$t" '$1==t{print $2,$3,$4,$5; exit}' <<< "$GEOM"; }

# verify cells via geometry; returns 0 if CAL=TL OBS=TR CHAT=BL ORCH=BR, 1 if wrong,
# 2 if geometry unavailable (cannot tell)
TOL=80
verify_cells() {
  refresh_geom
  [[ -z "$GEOM" ]] && return 2
  local minx="" miny="" wid x y
  for wid in "$CAL" "$OBS" "$CHAT" "$ORCH"; do
    set -- $(frame_of "$wid"); x="${1:-}"; y="${2:-}"
    [[ -z "$x" ]] && return 2
    [[ -z "$minx" || $x -lt $minx ]] && minx=$x
    [[ -z "$miny" || $y -lt $miny ]] && miny=$y
  done
  cell_of() { set -- $(frame_of "$1"); local c=""
    [[ ${2} -le $((miny+TOL)) ]] && c="T" || c="B"
    [[ ${1} -le $((minx+TOL)) ]] && c="${c}L" || c="${c}R"; echo "$c"; }
  [[ "$(cell_of "$CAL")" == "TL" && "$(cell_of "$OBS")" == "TR" \
     && "$(cell_of "$CHAT")" == "BL" && "$(cell_of "$ORCH")" == "BR" ]]
}

built=0
for attempt in $(seq 1 "$ATTEMPTS"); do
  echo "arrange-ws11: building grid (attempt $attempt/$ATTEMPTS)"
  if ! build_grid; then continue; fi
  verify_cells; rc=$?
  if [[ "$rc" -eq 0 ]]; then built=1; break; fi
  if [[ "$rc" -eq 2 ]]; then
    echo "  geometry unavailable; trusting deterministic build" >&2
    built=1; break
  fi
  echo "  cell verification failed; retrying" >&2
done
[[ "$built" -ne 1 ]] && { echo "arrange-ws11: grid build did not converge" >&2; exit 1; }

# ── Resize to the configured proportions (width from AppKit) ─────────
WIDTH=$(monitor_width "$TARGET_MON")
if [[ "$WIDTH" -gt 0 ]]; then
  resize_left() { # LEFT_ID PCT
    local delta=$(( WIDTH * $2 / 100 - WIDTH / 2 )) arg
    [[ $delta -ge 0 ]] && arg="+$delta" || arg="$delta"
    echo "arrange-ws11: resize win $1 -> width $arg (${2}% of ${WIDTH})"
    aerospace resize --window-id "$1" width "$arg" 2>/dev/null || true; sleep 0.2
  }
  resize_left "$CAL" "$TOP_LEFT_PCT"
  resize_left "$CHAT" "$BOT_LEFT_PCT"
else
  echo "arrange-ws11: could not read monitor width; leaving rows at 50/50" >&2
fi

echo "arrange-ws11: done."