#!/usr/bin/env bash
# Reload after changes: pkill sketchybar && sketchybar

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Show the bar on every monitor
sketchybar --bar height=28 position=top color=0xff1e1e2e display=all

# Event from AeroSpace
sketchybar --add event aerospace_workspace_change

# Create workspace indicators once
for sid in $(aerospace list-workspaces --all); do
    sketchybar --add item "space.$sid" left \
        --set "space.$sid" \
        background.color=0xff89b4fa \
        background.corner_radius=5 \
        background.height=20 \
        background.drawing=off \
        label="$sid" \
        label.color=0xff888888 \
        label.font="SF Pro:Bold:13.0" \
        label.padding_left=8 \
        label.padding_right=8 \
        click_script="aerospace workspace $sid"
done

# One hidden updater item that reassigns all spaces to the right monitor
sketchybar --add item aerospace_spaces_updater left \
    --set aerospace_spaces_updater drawing=off script="$PLUGIN_DIR/aerospace_sync_spaces.sh" \
    --subscribe aerospace_spaces_updater aerospace_workspace_change display_change system_woke

# Initial sync
"$PLUGIN_DIR/aerospace_sync_spaces.sh"
