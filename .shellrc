# Shared interactive shell config — sourced by both .bashrc and .zshrc

# Clear stale TMUX vars inherited from app launch environment
if [ -n "$TMUX" ] && ! tmux display -p '' 2>/dev/null; then
  unset TMUX TMUX_PANE
fi

# Make /etc/paths + /etc/paths.d apply even in non-login shells (tmux panes)
if [ -x /usr/libexec/path_helper ]; then
  eval "$(/usr/libexec/path_helper -s)"
fi

if [ -f ~/.localrc ]; then
  source ~/.localrc
fi

if [ -f ~/.shell_aliases ]; then
  . ~/.shell_aliases
fi

if [ -f ~/.shell_functions ]; then
  . ~/.shell_functions
fi

# PATH and environment (also sourced independently by .bash_profile/.zprofile
# for non-interactive login shells like AeroSpace exec-and-forget).
if [ -f ~/.shell_env ]; then
  . ~/.shell_env
fi

# Claude Agent Manager
[ -f ~/.claude/agent-manager/bin/shell-functions.sh ] && source ~/.claude/agent-manager/bin/shell-functions.sh

# pyenv interactive init (PATH/shims already set by .shell_env)
if command -v pyenv >> /dev/null 2>&1; then
  eval "$(pyenv init -)"
fi

set -o vi

# Ghostty workspace: keep the assigned title across shell prompts
if [[ -n "${GHOSTTY_WORKSPACE_TITLE:-}" ]]; then
  _ghostty_set_title() { printf '\033]0;%s\007' "$GHOSTTY_WORKSPACE_TITLE"; }
  if [[ -n "${ZSH_VERSION:-}" ]]; then
    precmd_functions+=(_ghostty_set_title)
  else
    PROMPT_COMMAND="_ghostty_set_title${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
  fi
fi

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
if [ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]; then
  . "$HOME/.sdkman/bin/sdkman-init.sh"
fi
