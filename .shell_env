# Environment and PATH — sourced by .bash_profile, .zprofile, and .shellrc
# so that PATH is available in login, interactive, AND non-interactive contexts.

export EDITOR=nvim

# Homebrew
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

export PATH=$HOME/.local/bin:$HOME/bin:$PATH

# pyenv
if command -v pyenv >> /dev/null 2>&1; then
  export PYENV_ROOT="$HOME/.pyenv"
  case "$PATH" in
    *"$PYENV_ROOT/bin"*) ;;
    *) export PATH="$PYENV_ROOT/bin:$PYENV_ROOT/shims:$PATH" ;;
  esac
fi

export SDKMAN_DIR="$HOME/.sdkman"
export PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"
export PATH="$HOME/ob-headless:$PATH"

export OBSIDIAN_VAULT="${OBSIDIAN_VAULT:-$HOME/obsidian}"

# Omnigent server URL — resolved per host (see ~/dotfiles/bin/omnigent-server-url).
# HUB serves locally; other devservers dial the HUB over the prod network; the
# Mac reaches it through the ET forward tunnel on loopback.
if [[ -z "${OMNIGENT_URL:-}" ]]; then
  if command -v omnigent-server-url >/dev/null 2>&1; then
    export OMNIGENT_URL="$(omnigent-server-url 2>/dev/null || echo http://127.0.0.1:6767)"
  else
    export OMNIGENT_URL="http://127.0.0.1:6767"
  fi
fi

# Local env (not source-controlled)
if [[ -f ~/.shell_env.local ]]; then
  source ~/.shell_env.local
fi

export CLAUDE_CODE_NO_FLICKER=0

